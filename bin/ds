#!/bin/bash
#===============================================================================
#
#          FILE: ds
# 
#         USAGE: ./ds 
# 
#   DESCRIPTION: Assistant script to the Draw Something game
# 
#       OPTIONS: ---
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (), kirk.roybal@2ndquadrant.com
#  ORGANIZATION: 
#       CREATED: 08/26/2019 15:32
#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error

ScriptVersion="1.0"

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  This utility will search a jumble of letters for words 
  of a specific length that appear in the English dictionary
  and are legal in the game of "Draw Something" on Android.
  
  Usage :  ${0##/*/} [options] [--] -s acegottz -l 7
cottage

  Options: 
  -a|add      [text] Add a word to the dictionary
  -d|deprecate [txt] Word is not used in the game
  -h|help            Display this message
  -l|length   [int]  Length of word being sought
  -s|scramble [text] Jumble of letters to search
  -v|version         Display script version

	EOT
}    # ----------  end of function usage  ----------

function die()
{
    #  Emit a message and quit with an error exit code

    echo -e "$1\n\n"
    usage
    exit 1
}

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------
word_length=-1
keyfield=

[[ $# -eq 0 ]] && die "No parameters were provided."

while getopts ":a:d:hl:s:v" opt
do
  case $opt in

    a|add      )  psql -qtAc "SELECT drawsomething_add('$OPTARG');" | sed -e 'd/^[[:space:]]*$/';;

    d|deprecate)  psql -qtAc "SELECT drawsomething_deprecate('$OPTARG');" | sed -e 'd/^[[:space:]]*$/';;

    h|help     )  usage; exit 0   ;;

    l|length   )  word_length=$OPTARG;;

    s|scramble )  keyfield=$OPTARG;;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))


[[ $word_length -eq -1 ]] && exit $?  # whatever the last command produced, or 0

[[ $word_length -lt 1 ]] && die "Target word length not reasonable."

[[ ${#keyfield} -lt 1 ]] && die "No characters provided to search."

[[ ${#keyfield} -lt $word_length ]] && die "Scrambled text not leng enough to contain words sought."

psql -qtAc "SELECT drawsomething_guess('$keyfield',$word_length);" | column
