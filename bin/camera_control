#!/bin/bash
#===============================================================================
#
#          FILE:  camera_control
# 
#         USAGE:  ./camera_control 
# 
#   DESCRIPTION:  Get the right control name for the service
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  01/09/2023 05:36:30 AM CST
#      REVISION:  ---
#===============================================================================

supported_controls="pan
tilt
zoom"
ScriptVersion="1.0"
camera="$(camera_select Aluratek)"  # Try the first camera
service="zoom"
display_value=0
new_value=

function die(){
    retval=$1
    shift
    echo -e "$@"
    exit $retval
}

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  e.g.:
    camera_select Aluratek
/dev/video0
    ${0##/*/} -gc "/dev/video0" -s "zoom"
zoom_absolute: 12
    ${0##/*/} -gc "/dev/video0" -s zoom -v 20
zoom_absolute: 20

  Options:
  -c|camera [name]   Get this from camera_select
  -g|get             Show the current value
  -s|service [name]  This is "pan", "tilt", or "zoom" 
  -h|help            Display this message
  -v|value [setting] Set the service if a value is present          
  -V|version         Display script version

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":c:dghs:v:V" opt
do
  case $opt in
    c|camera   )  camera="$OPTARG" ;;

    d|debug    )  set -x;;

    g|get      )  (( display_value++ )) ;;

    h|help     )  usage; exit 0   ;;

    s|service  )  service="$OPTARG" ;;

    v|value    )  new_value="$OPTARG";;

    V|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

[[ "${supported_controls[*]}" =~ "${service}" ]] || {
    usage
    die 1 "$service is not a recognized service."
}

service=$(v4l2-ctl --device "$camera" -l | grep "$service" | sed -e 's/ 0x.*$//' -e 's/[[:space:]]*//g')

[[ "${new_value}" == "" ]] || v4l2-ctl --device "$camera" --set-ctrl "${service}=${new_value}"
[[ ${display_value} -gt 0 ]] && v4l2-ctl --device "$camera" --get-ctrl "$service"
