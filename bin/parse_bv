CDP_BASE = os.environ.get("PARSE_BV_CDP_BASE", "http://127.0.0.1:9222").rstrip("/")
DASHBOARD_URL = os.environ.get("PARSE_BV_DASHBOARD", "https://www.beenverified.com/rf/dashboard")
VAULT = Path(os.environ.get("VAULT") or os.environ.get("Obsidian") or str(Path.home() / "Documents/notes"))
PEOPLE_DIR = VAULT / "people"
ASSETS_DIR = PEOPLE_DIR / "assets"
TEMPLATE = VAULT / "templates" / "New Person.md"
SOURCE_TAG = "beenverified"
TEMPLATE_ONLY_TAGS = {"🐘😇People", "DRW"}
