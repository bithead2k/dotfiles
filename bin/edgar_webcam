#!/bin/bash
#===============================================================================
#
#          FILE:  edgar_webcam
# 
#         USAGE:  ./edgar_webcam 
# 
#   DESCRIPTION:  manipulate the camera in the Alienware M15 R7 notebook
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  All parameters require an option, even if you are only reading
#                   (e.g. edgar_webcam -gb1 -c1 -e1 -p1 -s1 -w1)  # where the
#                   ones don't matter.  Like facts to a democrat.
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  02/24/2023 12:48:31 PM CST
#      REVISION:  ---
#===============================================================================

device=/dev/video0  # Since it's built in, it's always the 0 device
operation=setting
ScriptVersion="1.0"

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options: 
  -b|brightness
  -c|contrast
  -e|exposure
  -g|get
  -h|help          Display this message
  -l|list
  -p|power
  -s|set
  -v|version       Display script version
  -w|whitebalance

	EOT
}    # ----------  end of function usage  ----------

function doit(){

    [[ $operation == 'setting' ]] && 
        v4l2-ctl -d $device -c "$1=$2" ||
        v4l2-ctl -d $device -C "$1"
}

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------
while getopts ":b:c:de:ghlp:s:vw:" opt
do
  case $opt in

    b|brightness  )  doit brightness $OPTARG;;
    c|contrast    )  doit contrast $OPTARG;;
    d|debug       )  set -x ;;
    e|exposure    )  doit exposure_absolute $OPTARG;;
    g|get         )  operation=getting;; # show the current value of the requested thing
    h|help        )  usage; exit 0   ;;
    l|list        )  echo -e "
                   b|brightness: min=-64 max=64 step=1 default=0 value=0
                     c|contrast: min=0 max=95 step=1 default=0 value=0
                        p|power: min=0 max=2 default=2 value=2 (60 Hz)
                 w|whitebalance: min=2800 max=6500 step=1 default=4600 value=4600 flags=inactive
                       exposure: min=9 max=625 step=1 default=156 value=156 flags=inactive
                          g|get:
                          s|set: default"
                     exit
                     ;; # list the video controls
    p|power       )  doit power_line_frequency $OPTARG;;
    s|set         )  operation=setting;; # set the value of the requested thing
    v|version     )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;
    w|whitebalance)  doit white_balance_temperature $OPTARG;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))
