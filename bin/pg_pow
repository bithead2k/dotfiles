#!/usr/bin/env bash
# PostgreSQL Person of the Week — fetch interviews from postgresql.life
set -euo pipefail

OBSIDIAN="${OBSIDIAN:-$HOME/Documents/notes}"
PEOPLE_DIR="${OBSIDIAN}/people"
TEMPLATE="${TEMPLATE:-${OBSIDIAN}/templates/New Person.md}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOG_FILE="${CACHE_DIR}/pg_pow.log"
RSS_URL="https://postgresql.life/index.xml"
INTERVIEWS_URL="https://postgresql.life/categories/interviews/"
POW_TAG=$'🐘POW'

usage() {
    cat <<'EOF'
Usage: pg_pow [options] [name-or-slug]

Fetch a PostgreSQL Person of the Week interview from postgresql.life and
create or update a people note in the Obsidian vault.

Options:
  --latest       Use the newest RSS entry (for cron; skips if note exists)
  --backfill     Walk the full interview archive: create missing notes and
                 add the 🐘POW tag to existing ones when absent
  --markdown     Print note body to stdout (image + interview); no vault write
  --open         Open the note in Obsidian after creating (default for manual use)
  --quiet        No Obsidian URI; log only (implied by --latest and --backfill)
  -h, --help     Show this help

With no arguments, reads a name from the clipboard (xclip).
EOF
}

log() {
    mkdir -p "$(dirname "$LOG_FILE")"
    printf '%s pg_pow: %s\n' "$(date -Iseconds)" "$*" >>"$LOG_FILE"
}

resolve_person() {
    local query="${1:-}"
    python3 - "$query" "$RSS_URL" <<'PY'
import re
import sys
import urllib.request

query, rss_url = sys.argv[1], sys.argv[2]

def fetch(url):
    req = urllib.request.Request(url, headers={"User-Agent": "pg_pow/2.0"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        return resp.read().decode("utf-8")

def slugify(name):
    s = name.strip().lower()
    s = re.sub(r"[^\w\s-]", "", s, flags=re.UNICODE)
    return re.sub(r"[\s-]+", "_", s)

def resolve_slug(slug):
    url = f"https://postgresql.life/post/{slug}/"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "pg_pow/2.0"})
        with urllib.request.urlopen(req, timeout=30) as resp:
            if resp.status != 200:
                return None
            page = resp.read().decode("utf-8", errors="replace")
            if "post-container" not in page:
                return None
            title_m = re.search(r"<h1>([^<]+)</h1>", page)
            title = title_m.group(1).strip() if title_m else slug.replace("_", " ").title()
            return title, slug, url
    except Exception:
        return None

items = []
for block in re.findall(r"<item>(.*?)</item>", fetch(rss_url), re.DOTALL):
    title_m = re.search(r"<title>([^<]+)</title>", block)
    link_m = re.search(r"<link>([^<]+)</link>", block)
    if title_m and link_m:
        link = link_m.group(1).strip()
        slug = link.rstrip("/").split("/")[-1]
        items.append((title_m.group(1).strip(), slug, link))

if not items:
    raise SystemExit("pg_pow: no interviews in RSS feed")

if not query or query == "--latest":
    title, slug, link = items[0]
    print(f"{title}\t{slug}\t{link}")
    raise SystemExit(0)

q = query.strip()
q_slug = slugify(q)

for title, slug, link in items:
    if q_slug == slug or q.lower() == title.lower():
        print(f"{title}\t{slug}\t{link}")
        raise SystemExit(0)

resolved = resolve_slug(q_slug)
if resolved:
    title, slug, link = resolved
    print(f"{title}\t{slug}\t{link}")
    raise SystemExit(0)

names = ", ".join(t for t, _, _ in items[:5])
raise SystemExit(f"pg_pow: no match for {query!r} (recent: {names})")
PY
}

list_interviews() {
    python3 - "$INTERVIEWS_URL" <<'PY'
import re
import sys
import urllib.request

url = sys.argv[1]

def fetch(target):
    req = urllib.request.Request(target, headers={"User-Agent": "pg_pow/2.0"})
    with urllib.request.urlopen(req, timeout=60) as resp:
        return resp.read().decode("utf-8", errors="replace")

html = fetch(url)
slugs = []
seen = set()
for slug in re.findall(r"/post/([\w_]+)/", html):
    if slug == "postgresql_person_of_the_week" or slug in seen:
        continue
    seen.add(slug)
    slugs.append(slug)

for slug in slugs:
    print(f"https://postgresql.life/post/{slug}/")
PY
}

fetch_markdown() {
    local link="$1"
    python3 - "$link" <<'PY'
import html
import re
import sys
import urllib.request
from html.parser import HTMLParser

link = sys.argv[1]
base = link if link.endswith("/") else link + "/"

def fetch(url):
    req = urllib.request.Request(url, headers={"User-Agent": "pg_pow/2.0"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        return resp.read().decode("utf-8", errors="replace")

def head_ok(url):
    req = urllib.request.Request(url, method="HEAD", headers={"User-Agent": "pg_pow/2.0"})
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return 200 <= resp.status < 400
    except Exception:
        return False

def resolve_image(slug, page):
    og_m = re.search(r'property="og:image:url" content="([^"]+)"', page)
    candidates = []
    if og_m:
        candidates.append(og_m.group(1))
    candidates.extend(
        [
            f"https://postgresql.life/images/posts/{slug}_600.jpg",
            f"https://postgresql.life/post/{slug}/{slug}_600.jpg",
            f"https://postgresql.life/post/{slug}/{slug}.jpg",
        ]
    )
    seen = set()
    for url in candidates:
        if url in seen:
            continue
        seen.add(url)
        if head_ok(url):
            return url
    return candidates[0]

class ToMarkdown(HTMLParser):
    def __init__(self, base_url):
        super().__init__(convert_charrefs=True)
        self.base = base_url
        self.parts = []
        self.link_stack = []
        self.skip = 0

    def handle_starttag(self, tag, attrs):
        attrs = dict(attrs)
        if self.skip:
            self.skip += 1
            return
        if tag in ("script", "style"):
            self.skip = 1
            return
        if tag == "h3":
            self._break()
            self.parts.append("### ")
        elif tag == "h4":
            self._break()
            self.parts.append("#### ")
        elif tag == "p":
            self._break()
        elif tag == "br":
            self.parts.append("\n")
        elif tag == "li":
            self._break()
            self.parts.append("-   ")
        elif tag == "a":
            href = attrs.get("href") or ""
            if href.startswith("/"):
                href = "https://postgresql.life" + href
            elif href and not href.startswith(("http://", "https://", "mailto:")):
                href = self.base + href.lstrip("/")
            self.link_stack.append(href)
            self.parts.append("[")
        elif tag == "img":
            src = attrs.get("src") or ""
            alt = attrs.get("alt") or ""
            if src.startswith("/"):
                src = "https://postgresql.life" + src
            elif src and not src.startswith("http"):
                src = self.base + src.lstrip("/")
            self.parts.append(f"![{alt}]({src})")
        elif tag == "figcaption":
            self._break()
            self.parts.append("#### ")

    def handle_endtag(self, tag):
        if self.skip:
            self.skip -= 1
            return
        if tag in ("h3", "h4", "figcaption"):
            self.parts.append("\n\n")
        elif tag == "p":
            self.parts.append("\n\n")
        elif tag == "li":
            self.parts.append("\n")
        elif tag == "a":
            if self.link_stack:
                href = self.link_stack.pop()
                self.parts.append(f"]({href})")

    def handle_data(self, data):
        if not self.skip:
            self.parts.append(data)

    def _break(self):
        if self.parts and not self.parts[-1].endswith("\n"):
            self.parts.append("\n")

    def get_markdown(self):
        text = "".join(self.parts)
        text = html.unescape(text)
        text = re.sub(r"\n{3,}", "\n\n", text)
        return text.strip()

page = fetch(link)
title_m = re.search(r"<h1>([^<]+)</h1>", page)
title = title_m.group(1).strip() if title_m else ""
slug = link.rstrip("/").split("/")[-1]
image = resolve_image(slug, page)

m = re.search(
    r"<div class=post-container>(.*?)</div>\s*<br><br>\s*<a class=resp-sharing",
    page,
    re.DOTALL,
)
if not m:
    m = re.search(r"<div class=post-container>(.*?)</div>", page, re.DOTALL)
container = m.group(1) if m else ""

parser = ToMarkdown(base)
parser.feed(container)
body = parser.get_markdown()

print(f"TITLE:{title}")
print(f"IMAGE:{image}")
print("BODY:")
print(body)
PY
}

parse_fetched() {
    local parsed="$1"
    PARSED_TITLE=$(printf '%s\n' "$parsed" | sed -n 's/^TITLE://p' | head -1)
    PARSED_IMAGE=$(printf '%s\n' "$parsed" | sed -n 's/^IMAGE://p' | head -1)
    PARSED_BODY=$(printf '%s\n' "$parsed" | awk 'found{print} /^BODY:$/{found=1}')
}

ensure_pow_tag() {
    local file="$1"
    python3 - "$file" "$POW_TAG" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
pow_tag = sys.argv[2]
text = path.read_text(encoding="utf-8")

if not text.startswith("---\n"):
    raise SystemExit(1)

end = text.find("\n---\n", 4)
if end == -1:
    raise SystemExit(1)

fm, body = text[4:end], text[end + 5 :]
if pow_tag in fm:
    raise SystemExit(1)

lines = fm.splitlines()
out = []
modified = False
i = 0
while i < len(lines):
    line = lines[i]
    if line.startswith("tags:"):
        out.append(line)
        i += 1
        tag_lines = []
        while i < len(lines) and re.match(r"^\s*-\s+", lines[i]):
            tag_lines.append(lines[i])
            i += 1
        out.extend(tag_lines)
        if not any(pow_tag in tl for tl in tag_lines):
            out.append(f" - {pow_tag}")
            modified = True
        continue
    out.append(line)
    i += 1

if not modified:
    inserted = False
    rebuilt = []
    for line in out:
        if not inserted and line.startswith(("date:", "company:", "attention:", "aliases:")):
            rebuilt.extend(["tags:", f" - {pow_tag}", ""])
            inserted = True
            modified = True
        rebuilt.append(line)
    if not inserted:
        rebuilt.extend(["tags:", f" - {pow_tag}"])
        modified = True
    out = rebuilt

if not modified:
    raise SystemExit(1)

path.write_text("---\n" + "\n".join(out) + "\n---\n" + body, encoding="utf-8")
raise SystemExit(0)
PY
}

build_note() {
    local name="$1" image="$2" body="$3"
    [[ -f "$TEMPLATE" ]] || { echo "pg_pow: template not found: $TEMPLATE" >&2; exit 1; }

    python3 - "$TEMPLATE" "$name" "$image" "$body" "$POW_TAG" <<'PY'
import sys
from datetime import date
from pathlib import Path

template_path, name, image, body, pow_tag = sys.argv[1:6]
text = Path(template_path).read_text(encoding="utf-8")
today = date.today().isoformat()
parts = name.split(None, 1)
first = parts[0]
last = parts[1] if len(parts) > 1 else ""

out = []
for line in text.splitlines():
    if line.startswith("first_name:"):
        out.append(f"first_name: {first}")
    elif line.startswith("last_name:"):
        out.append(f"last_name: {last}")
    elif line.startswith("date:"):
        out.append(f"date: {today}")
    elif line.strip() == "- DRW":
        continue
    elif line.strip() == "- 🐘😇People":
        out.append(line)
        out.append(f" - {pow_tag}")
    elif line.startswith("company:"):
        out.append("company: ")
    elif line == "![|250]()":
        out.append(f"![{name}|250]({image})")
    else:
        out.append(line.replace("{{title}}", name).replace("{{date}}", today))

note = "\n".join(out).rstrip()
if body.strip():
    note = f"{note}\n\n{body}"
print(note)
PY
}

create_person_note() {
    local person_name="$1" person_link="$2"
    local note_file="${PEOPLE_DIR}/${person_name}.md"

    mkdir -p "$PEOPLE_DIR"
    build_note "$person_name" "$PARSED_IMAGE" "$PARSED_BODY" >"$note_file"
    obsidian_ensure_filename_alias "$note_file"
    log "created ${person_name} (${person_link})"
    echo "pg_pow: created ${note_file}"
}

update_existing_note() {
    local person_name="$1"
    local note_file="${PEOPLE_DIR}/${person_name}.md"

    if ensure_pow_tag "$note_file"; then
        log "tagged ${person_name}"
        echo "pg_pow: added ${POW_TAG} tag to ${note_file}"
        return 0
    fi

    log "skip existing note: ${person_name}"
    [[ "${quiet:-0}" -eq 0 ]] && echo "pg_pow: ${note_file} already exists"
    return 1
}

process_person() {
    local person_link="$1"
    local parsed

    parsed=$(fetch_markdown "$person_link")
    parse_fetched "$parsed"
    [[ -n "$PARSED_TITLE" ]] || { log "skip unreadable interview: ${person_link}"; return 2; }

    local person_name="$PARSED_TITLE"
    local note_file="${PEOPLE_DIR}/${person_name}.md"

    if [[ -f "$note_file" ]]; then
        update_existing_note "$person_name"
        return 3
    fi

    create_person_note "$person_name" "$person_link"

    if [[ "${open_obsidian:-0}" -eq 1 ]]; then
        obsidian_cli -of "people/${person_name}"
    fi
    return 0
}

run_backfill() {
    local link created=0 tagged=0 skipped=0 failed=0

    while IFS= read -r link; do
        [[ -z "$link" ]] && continue
        set +e
        parsed=$(fetch_markdown "$link")
        parse_fetched "$parsed"
        if [[ -z "$PARSED_TITLE" ]]; then
            log "backfill skip unreadable: ${link}"
            ((failed++)) || true
            set -e
            continue
        fi

        note_file="${PEOPLE_DIR}/${PARSED_TITLE}.md"
        if [[ -f "$note_file" ]]; then
            if ensure_pow_tag "$note_file"; then
                log "backfill tagged ${PARSED_TITLE}"
                ((tagged++)) || true
            else
                ((skipped++)) || true
            fi
        else
            create_person_note "$PARSED_TITLE" "$link" >/dev/null
            ((created++)) || true
        fi
        set -e
    done < <(list_interviews)

    echo "pg_pow backfill: created ${created}, tagged ${tagged}, unchanged ${skipped}, failed ${failed}"
    log "backfill complete: created=${created} tagged=${tagged} unchanged=${skipped} failed=${failed}"
}

mode="create"
query=""
open_obsidian=1
quiet=0
backfill=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --latest) query="--latest" ;;
        --backfill) backfill=1 ;;
        --markdown) mode="markdown" ;;
        --open) open_obsidian=1 ;;
        --quiet) quiet=1; open_obsidian=0 ;;
        -h|--help) usage; exit 0 ;;
        -*) echo "pg_pow: unknown option $1" >&2; usage >&2; exit 1 ;;
        *) query="$1" ;;
    esac
    shift
done

if [[ "$backfill" -eq 1 ]]; then
    quiet=1
    open_obsidian=0
    run_backfill
    exit 0
fi

if [[ -z "$query" ]]; then
    if command -v xclip >/dev/null 2>&1; then
        query=$(xclip -o 2>/dev/null | head -1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    fi
    [[ -z "$query" ]] && { echo "pg_pow: provide a name or use --latest" >&2; usage >&2; exit 1; }
fi

[[ "$query" == "--latest" ]] && quiet=1 && open_obsidian=0

IFS=$'\t' read -r person_name slug person_link < <(resolve_person "$query")

parsed=$(fetch_markdown "$person_link")
parse_fetched "$parsed"
[[ -n "$PARSED_TITLE" ]] && person_name="$PARSED_TITLE"

if [[ "$mode" == "markdown" ]]; then
    build_note "$person_name" "$PARSED_IMAGE" "$PARSED_BODY"
    exit 0
fi

note_file="${PEOPLE_DIR}/${person_name}.md"
if [[ -f "$note_file" ]]; then
    update_existing_note "$person_name"
    exit 0
fi

create_person_note "$person_name" "$person_link"

if [[ "$open_obsidian" -eq 1 ]]; then
    obsidian_cli -of "people/${person_name}"
fi