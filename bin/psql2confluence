set -o nounset                              # Treat unset variables as an error

#add pipes to the beginning and end of all rows, double the pipes on the header line, and trim the row count.
cat - | sed -e '/^[+-|]*$/d' -e 's/^/|/' -e 's/$/|/' -e '1s/|/||/g' -e '/(.*row.*)/d' 
