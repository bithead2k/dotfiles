#!/bin/bash - 
#===============================================================================
#
#          FILE: csv2psql
# 
#         USAGE: ./csv2psql 
# 
#   DESCRIPTION: 
# 
#       OPTIONS: ---
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (KLR), kroybal@tripadvisor.com
#  ORGANIZATION: 
#       CREATED: 08/24/2016 11:21
#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error

debug=0
table_name=""
ScriptVersion="1.0"
separator=','

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options:
  -d|debug           Cumulative debug flag (e.g. -ddd) 
  -h|help            Display this message
  -f|file    [name]  CSV file of data with header
  -s|separator char  Single character CSV column delineator
  -t|table   [name]  Table to insert data
  -v|version         Display script version

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":df:hs:t:v" opt
do
  case $opt in
    d|debug    )  (( debug++ ));;

    h|help     )  usage; exit 0   ;;

    f|file     )  file_name="$OPTARG";;

    s|separator)  separator="$OPTARG'";;

    t|table    )  table_name="$OPTARG";;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

[[ ${#separator} -eq 1 ]] || {
    usage
    exit 0
}

[[ $table_name == "" ]] && {
    usage
    exit 0
}

[[ $file_name == "" ]] && {
    usage
    exit 0
}

function construct_sql(){

    sql="SELECT oid FROM pg_class WHERE relname='$1';"

    oid=$(psql -qtAc "$sql")

    sql="SELECT attname FROM pg_attribute WHERE attrelid='$oid' AND attname NOT IN ('tableoid','cmax','xmax','cmin','xmin','ctid','id','inserted') ORDER BY attnum;"

    fields=$(psql -qtAc "$sql" | tr '\n' ',' | sed 's/,$//')
    
    sql="COPY $table_name ($fields) FROM STDIN WITH CSV HEADER DELIMITER E'$separator';"

    echo -e "$sql"

    [[ $debug -gt 0 ]] && echo "$sql" >&2

}


[[ $debug -gt 0 ]] && echo "cat $file_name | psql -qtAc \"$(construct_sql $table_name)\""

cat $file_name | psql -qtAc "$(construct_sql $table_name)"
