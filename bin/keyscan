#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error

# scan a keycode to map
xev | grep -A2 --line-buffered '^KeyRelease' | sed -n '/keycode /s/^.*keycode \([0-9]*\).* (.*, \(.*\)).*$/\1 \2/p'
