#!/bin/bash
# Add a note to Obsidian on today's note in section made for this.
today=$(date +'%Y_%m_%d')
prefix=~/Documents/notes/
notefile=${prefix}journals/${today}.md
tasks=${prefix}snippets/tasks.md
section_name="Interstitial"
rightarrow="⟶"
mdash="—"
doubledash="--"
question="?"
separator=${doubledash}
li="*"
dojournal=
ScriptVersion="1.5"
task=0
logging=0
goal="Daily goals"
list_interstitial=0
list_goals=0
list_stretch=0
goal_add=""
file_lines=0
divider=0
section_start=

function refresh_journal_layout() {
    [[ -f "${notefile}" ]] || return 1
    file_lines=$(wc -l < "${notefile}")
    divider=$(grep -n "<hr style='border-width: 6px; border-color:white'/>" "${notefile}" |
        tail -n 1 | sed -e 's/:.*$//')
    section_start=$(awk "/${section_name}/ && NR >= $divider && NR <= $((divider + 4)) { print NR }" "${notefile}")
}

if [[ -f "${notefile}" ]]; then
    refresh_journal_layout
    (( div_plus4=divider+4 ))
fi

function interstitial_item_lines() {
    local start i line
    refresh_journal_layout || return 1
    [[ -n "${section_start}" ]] || return 1
    start=$((section_start + 2))
    for ((i = start; i <= file_lines; i++)); do
        line=$(sed -n "${i}p" "${notefile}")
        [[ "$line" =~ \<hr\ style=\'border-width:\ 5px ]] && break
        [[ "$line" =~ ^[[:space:]]*[\*-] ]] && echo "$i"
    done
}

function list_interstitial_items() {
    local n=0 line lineno
    refresh_journal_layout || {
        echo "No journal for today: ${notefile}" >&2
        return 1
    }
    [[ -n "${section_start}" ]] || {
        echo "No ${section_name} section in ${notefile}" >&2
        return 1
    }
    while read -r lineno; do
        n=$((n + 1))
        line=$(sed -n "${lineno}p" "${notefile}")
        printf '%4d  %s\n' "$n" "$line"
    done < <(interstitial_item_lines)
    [[ "$n" -eq 0 ]] && echo "(empty)"
    return 0
}

function list_goal_items() {
    local header_pattern=$1 label=$2 stop_pattern=$3
    local section_line start i line n=0
    [[ -f "${notefile}" ]] || {
        echo "No journal for today: ${notefile}" >&2
        return 1
    }
    file_lines=$(wc -l < "${notefile}")
    section_line=$(grep -n "${header_pattern}" "${notefile}" | head -n 1 | cut -d: -f1)
    [[ -n "${section_line}" ]] || {
        echo "No ${label} section in ${notefile}" >&2
        return 1
    }
    start=$((section_line + 2))
    for ((i = start; i <= file_lines; i++)); do
        line=$(sed -n "${i}p" "${notefile}")
        [[ "$line" =~ ${stop_pattern} ]] && break
        [[ "$line" =~ ^[[:space:]]*[\*-].*\[ ]] && {
            n=$((n + 1))
            printf '%4d  %s\n' "$n" "$line"
        }
    done
    [[ "$n" -eq 0 ]] && echo "(empty)"
    return 0
}

function gojournal(){
    lineno=${1}
    gvim +${lineno} +'normal $A   ' +startinsert "${notefile}"
}

function last_line(){

	for ((i=${section_start};i<=${file_lines};i++ ))
	do
	    comment=$(cat "${notefile}" | head -n $i | tail -n 1 | grep '^[[:space:]]*[\*-]')
	    [[ "$comment" == "" ]] && break
	done
	
	(( i-- ))
	
	return ${i}
	echo "${i}"

}

function get_task(){

    sed -n "$1p" "${tasks}"

}

function list_tasks(){
    cat "${notefile}" | column
}

function remove_task_item() {
    local n=$1 count
    [[ -f "${tasks}" ]] || {
        echo "No task list: ${tasks}" >&2
        return 1
    }
    count=$(wc -l < "${tasks}")
    [[ "$n" =~ ^[0-9]+$ ]] && [[ "$n" -ge 1 && "$n" -le "$count" ]] || {
        echo "Invalid task number: ${n} (use: o, then o -x NUMBER)" >&2
        return 1
    }
    sed -i "${n}d" "${tasks}"
    echo "Removed task #${n} from ${tasks}"
    cat -n "${tasks}" | column -t --separator $'\n'
}

function goal_section_start() {
    local header_pattern=$1
    local section_line
    section_line=$(grep -n "${header_pattern}" "${notefile}" | head -n 1 | cut -d: -f1)
    [[ -n "${section_line}" ]] || return 1
    echo $((section_line + 2))
}

function add_daily_goal() {
    local header_pattern insert_before start i line text=$*
    [[ -f "${notefile}" ]] || {
        echo "No journal for today: ${notefile}" >&2
        exit 1
    }
    file_lines=$(wc -l < "${notefile}")

    if [[ "${goal}" == "Stretch goals" ]]; then
        header_pattern='Stretch [Gg]oals'
        insert_before='<hr'
    else
        header_pattern='Daily goals'
        insert_before='^[[:space:]]*---'
    fi

    start=$(goal_section_start "${header_pattern}") || {
        echo "No ${goal} section in ${notefile}" >&2
        exit 1
    }

    for ((i = start; i <= file_lines; i++)); do
        line=$(sed -n "${i}p" "${notefile}")
        [[ "$line" =~ ${insert_before} ]] && break
        if [[ "$line" =~ ^[[:space:]]*[\*-][[:space:]]*-[[:space:]]*\[[[:space:]]\][[:space:]]*$ ]]; then
            sed -i "${i}s/[ ]]/[ ] ${text}/" "$notefile"
            exit 0
        fi
    done

    for ((i = start; i <= file_lines; i++)); do
        line=$(sed -n "${i}p" "${notefile}")
        [[ "$line" =~ ${insert_before} ]] && {
            sed -i "${i}i\\ * - [ ] ${text}" "$notefile"
            exit 0
        }
    done

    echo "Could not add ${goal} to ${notefile}" >&2
    exit 1
}

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options:
  -a            Long right arrow 
  -c            Checkbox
  -d|debug      
  -g|goal  text Add daily goal (-a/-m etc. ignored; e.g. o -g "goal text")
  -G            List today's daily goals (numbered)
  -h|help       Display this message
  -i            List today's interstitial log (numbered)
  -j|journal    Open today's interstitial journal
  -l|logging    Cumulative logging (e.g. -lll)
  -m            mDash
  -s|stretch text Add stretch goal (-a/-m etc. ignored; e.g. o -s "goal text")
  -S            List today's stretch goals (numbered)
  -t  number    Add a task by the number
  -T  text      Add a task to the task list
  -x  number    Remove a task from the task list (opposite of -T; see plain o)
  -q            Question
  -v|version    Display script version

  o              List reusable tasks (snippets/tasks.md)
  o -i           List today's interstitial log entries
  o -G           List today's daily goals
  o -S           List today's stretch goals

For a list of tasks, just invoke ${0##/*/} with no parameters

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":acdgGhjilmqs:t:T:Svx:" opt
do
  case $opt in

    a          ) separator=${rightarrow};;

    c          ) li=" - [ ]";;

    d|debug    ) set -x;;

    g|goal     ) goal_add=daily;;

    G          ) list_goals=1;;

    h|help     )  usage; exit 0   ;;

    i          ) list_interstitial=1;;

    j|journal  )  dojournal=true;;

    l|logging  ) (( logging++ )); [[ $logging -gt 2 ]] && set -x;;
   
    m          )  separator=${mdash};;

    s|stretch  ) goal_add=stretch;;

    S          ) list_stretch=1;;

    t          )  task="${OPTARG}";;

    T          )  shift; echo -n "${*}" >> "${tasks}"; cat "${tasks}" | sort | uniq > "${tasks}.tmp"; mv "${tasks}.tmp" "${tasks}"; exit;;

    x          ) remove_task_item "${OPTARG}"; exit;;

    q          )  separator=${question};;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

[[ "${list_interstitial}" -eq 1 ]] && { list_interstitial_items; exit; }
[[ "${list_goals}" -eq 1 ]] && { list_goal_items 'Daily goals' 'Daily goals' '^[[:space:]]*---|^\*\*Stretch'; exit; }
[[ "${list_stretch}" -eq 1 ]] && { list_goal_items 'Stretch [Gg]oals' 'Stretch goals' "\<hr"; exit; }

if [[ -n "${goal_add}" ]]; then
    [[ "${goal_add}" == stretch ]] && goal="Stretch goals"
    [[ -z "$*" ]] && {
        [[ "${goal_add}" == stretch ]] && echo 'Missing stretch goal text (e.g. o -s "goal text")' >&2
        [[ "${goal_add}" != stretch ]] && echo 'Missing daily goal text (e.g. o -g "goal text")' >&2
        exit 1
    }
    add_daily_goal "$*"
    exit 0
fi

#  if all we got was 'o -j', just open today's journal
[[ "$*" == "" ]] && [[ "$dojournal" ]] && {
    [[ $logging -gt 0 ]] && echo "Opening today's journal: ${notefile}"
    gojournal ${file_lines} && exit
}

[[ "$*" == "" ]] || [[ "${dojournal}" ]] && [[ "${task}" == 0 || ! "${task}" =~ ^[0-9]+$ ]] && cat -n "${tasks}" | column -t --separator $'\n' && exit

# Fix some shell quoting issues
if [[ ! "$*" == "" ]]; then
    quoted=${*//\'/\\\'}
elif [[ "${task}" =~ ^[0-9]+$ ]]; then
    quoted=$(get_task "${task}")
else
    quoted=""
fi
quoted=${quoted//\"/\\\"}
quoted=" $li ==$(date +"%H:%M:%S")== ${separator}  ${quoted}"
[[ $logging -gt 1 ]] && echo "$quoted"

# If today's journal doesn't exist, make it
# (should never run.  Journals are pre-made to 2026
[[ -f "${notefile}" ]] || newjournal -d $(today)
refresh_journal_layout
(( div_plus4=divider+4 ))

# Add a section if it doesn't exist.
[[ "${section_start}" == "" ]] && {
    [[ $logging -gt 1 ]] && echo "Creating ${section_name} section"
    # There is no section.  Just make it happen
    # Also, add another horizontal bar below the section
    # (that isn't exactly the same, so we don't stomp ourselves)
    # (notice it's 5px :)
    sed -ie "${divider}a\\
\\
# ${section_name}\\
\\
${quoted}\\
\\
<hr style='border-width: 5px; border-color:white'/>\\
 " "${notefile}"

    [[ "$dojournal" ]] && dojournal ${div_plus4}
    exit

}


# skip the section header and the next blank line
(( section_start++ ))
(( section_start++ ))
# run to the end of the file, 
# but we probably won't need 
# anywhere near that much buffer
last_line
insertion=$?
[[ $logging -gt 0 ]] && echo "Insertion point: $insertion"
# Starting at the last line that was a list item, 
# insert the new comment
# Get the start time of the previous item
stime=$(head -n ${insertion} "${notefile}" | tail -n 1 | sed -e 's/^\(.*\)==.*$/\1/' -e 's/^.*==//')
start_sec=$(date --date "$stime" +%s 2>/dev/null)
end_sec=$(date +%s)
if [[ -n "$start_sec" && "$start_sec" =~ ^[0-9]+$ ]]; then
    diff_sec=$((end_sec - start_sec))
    if (( diff_sec >= 0 && diff_sec < 120 )); then
        [[ $diff_sec -eq 1 ]] && plural="" || plural="s"
        duration_suffix=" | ${diff_sec} second${plural}"
        [[ $logging -gt 0 ]] && echo "${diff_sec} second${plural}"
    else
        diff_minutes=$((diff_sec / 60))
        [[ $diff_minutes -eq 1 ]] && plural="" || plural="s"
        duration_suffix=" | ${diff_minutes} minute${plural}"
        [[ $logging -gt 0 ]] && echo "${diff_minutes} minute${plural}"
    fi
    [[ ! -z "${insertion}" ]] && sed -ie "${insertion}s/$/${duration_suffix}/" "${notefile}"
fi

# Append the bullet item to the end of the section
[[ ! -z "${insertion}" ]] && sed -ie "${insertion}a\\
${quoted}" "${notefile}"
[[ $logging -gt 1 ]] && echo "sed returned $?"
(( insertion++ ))
[[ "$dojournal" ]] && gojournal ${insertion}
exit 0