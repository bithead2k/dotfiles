#!/bin/bash
#===============================================================================
#
#          FILE:  newjournal
# 
#         USAGE:  ./newjournal 
# 
#   DESCRIPTION:  Make a new journal in obsidian
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  01/23/2023 12:32:08 AM CST
#      REVISION:  
#  1.0 Create a rational new journal for Obsidian
#  1.1 Added parameters to just do a TODO: rollover
#  1.2 Teach the script to take a date on the comand line
#
#===============================================================================

set +o noclobber
ScriptVersion="1.1"
thedate=$(date +"%F")
obsidiandir=~/Documents/notes/
journaldir="${obsidiandir}journals/"
tododir="${obsidiandir}todo/"
todofile="${tododir}${thedate}.md"
journalfile="${journaldir}${thedate//-/_}.md"
# echo "${journalfile}"


#===  FUNCTION  ================================================================
#          NAME:  datediff
#   DESCRIPTION:  count of days between two dates
#    PARAMETERS:  date1, date2
#       RETURNS:  integer
#===============================================================================
datediff() {
    d1=$(date -d "$1" +%s)
    d2=$(date -d "$2" +%s)
    echo $(( (d1 - d2) / 86400 ))
}

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [date] [--] 

  Options:
  -d|date [date] Change the output date
  -h|help        Display this message
  -l|log         Verbose bash debugging
  -r|rollover    Just rollover the todo list
  -v|version     Display script version

	EOT
}    # ----------  end of function usage  ----------


#===  FUNCTION  ================================================================
#          NAME:  todo_rollover
#   DESCRIPTION:  copies the unchecked items from the latest todo list
#    PARAMETERS:  none
#       RETURNS:  creates a new file with the given date in the todo inode
#===============================================================================
function todo_rollover() {
    
    # Get rid of stray empty files
    pushd "${tododir}" >/dev/null 2>&1
    find . -type f -empty -print -delete
    popd > /dev/null 2>&1
    # Find the last day a todo list exists
    previous_day="${tododir}$(ls -1 ${tododir} | 
        grep "^[[:digit:]]\{4\}-[[:digit:]]\{2\}-[[:digit:]]\{2\}.md" | # only care about files with date names
        sort | tail -n 1)"
    # If the last day is today, we already rolled over
    #   don't screw ourselves
    [[ "${previous_day}" == "${tododir}${thedate}.md" ]] && return
    # See if there's anything finished on it
    done=$(cat "${previous_day}" | grep "\[x\]")
    [[ "$done" == "" ]] && {
        # Nothing was done, so just move the file to today
        cp "$previous_day" "${todofile}"
        exit
    }

    # Create the new todo list
    psql -qtAc "TRUNCATE todo_reorder;"

	IFS=$'\n'
	for todo in $(cat "${previous_day}")
	do
	    # Is this a header or an item?
	      # Take the left two characters,
	      # remove spaces, and you should be
	      # left with a dash
	    todoheader=$(echo "${todo:0:2}" | sed -e '/^\t/d' | sed -e 's/[[:space:]]*//g')
	    [[ "$todoheader" == "-" ]] && {
	      # If this is a "leftmost" check, it is a header.
            parent_id=$(psql -qtAc "INSERT INTO todo_reorder 
            (parent_id,item) 
                VALUES (0,'$todo')
                RETURNING id;")
	    } || {
            # otherwise, it's a child
            psql -qtAc "INSERT INTO todo_reorder 
                (parent_id, item)
            VALUES ($parent_id, '$todo')"
        }
	done

    psql -qtAc "UPDATE todo_reorder 
    SET checked = true
    WHERE item ~* '\[x\]';"

sql="WITH top AS (
    SELECT * 
    FROM todo_reorder 
    WHERE parent_id = 0)
, bottom AS (
    SELECT * 
    FROM todo_reorder 
    WHERE parent_id <> 0 
        AND NOT checked)
, matches AS (
    SELECT top.*, bottom.item bottom, 
        bottom.id bottom_id 
    FROM top 
    LEFT JOIN bottom 
        ON (top.id) = (bottom.parent_id)) 
SELECT trim(item), 
    '    ' || trim(regexp_replace(bottom,'\t','  ','g')) bottom
FROM matches
WHERE NOT (checked 
AND bottom IS NULL)
ORDER BY id, bottom_id;"

    oldtop=""
    top=""
    IFS=$'\n'
    for item in $(psql -qtAc "$sql")
    do
        top=$(echo -e "$item" | cut -d'|' -f1) 
        [[ "$top" == "$oldtop" ]] || {
            echo -e "$top"
            oldtop="$top"
        }
        echo -e "$item" | cut -d'|' -f2
    done | sed '/^$/d' >> "${tododir}${thedate}.md"  # get rid of empty lines

    psql -qtAc "TRUNCATE todo_reorder;"
}

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":d:hlrv" opt
do
  case $opt in
    
    d|date     ) thedate=$(date --date="$OPTARG" +"%F")
                 todofile="${tododir}${thedate}.md"
                 journalfile="${journaldir}${thedate//-/_}.md"
                 ;;

    h|help     )  usage; exit 0   ;;

    l|log      )  set -x;;

    r|rollover )  todo_rollover; exit 0 ;;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

yesterday=$(date --date="$thedate -1 day" +"%Y_%m_%d")
tomorrow=$(date --date="$thedate +1 day" +"%Y_%m_%d")
lastweek=$(date --date="$thedate -7 days" +"%Y_%m_%d")
nextweek=$(date --date="$thedate +7 days" +"%Y_%m_%d")
deathclock=$(datediff 2048-11-14 $thedate)

[[ -f "$journalfile" ]] && {

	header="
# 

Entry: **$(date +"%F %T CST")**

"
	echo -e "${header}" >> ${journalfile}

    exit    
#	gvim ${journalfile} &
}

read -r -d '' header <<-EOF
---
title               : Personal Journal
date                : ${thedate}
copyright-years     : $(date --date="${thedate}" +"%Y")
copyright           : $(date --date="${thedate}" +"%Y")
copyright-year-from : $(date --date="${thedate}" +"%Y")
toc                 : true
company             : Personal
author              : Kirk L. Roybal
tags                : 
 - 📝journal
Sleep               : 😐
Bible_Study         : false
Exercise            : false
Literature          : false
Language            : false
Handwriting         : false
Assistance          : false
Make                : false
Read                : false
Think               : false
Say                 : false
Discover            : false
Improve             : false
Learn               : false
---

Personal Journal for $thedate
Modified: \`= dateformat(this.file.mtime,"yyyy-MM-dd") \`

$deathclock

<hr style='border-width: 6px; border-color:white'/>

[toc]


\`\`\`dataviewjs
const thisone = dv.current();
const notes = dv.pages('"people"').filter(page => page.birthday).filter(page => page.birthday.month == thisone.date.month && page.birthday.day == thisone.date.day);
if (notes.length) dv.paragraph("<hr style='border-width: 3px; border-color:white'/>");
if (notes.length) dv.paragraph("**Birthdays**");
if (notes.length) dv.list(notes.file.link);
\`\`\`

<hr style='border-width: 3px; border-color:white'/>

\`= "sleep: " + this.sleep + "| bible: " + choice(this.Bible_Study,"✅","🔥") + "| exercise: " + choice(this.exercise,"✅","❌") + "| lit: " + choice(this.literature,"✅","❌") + "| lang: " + choice(this.language,"✅","❌") + "| write: " + choice(this.handwriting,"✅","❌") + "| help: " + choice(this.assistance,"✅","❌") \`
\`= "make: " + choice(this.make,"✅","❌") + "| read: " + choice(this.read,"✅","❌") + "| think: " + choice(this.think,"✅","❌") + "| say: " + choice(this.say,"✅","❌") + "| discover: " + choice(this.discover,"✅","❌") + "| improve: " + choice(this.improve,"✅","❌") + "| learn: " + choice(this.learn,"✅","❌") \`

<hr style='border-width: 3px; border-color:white'/>

**Daily goals:**

 - [ ] 
 - [ ] 
 - [ ] 
---
**Stretch goals:**

 - [ ] 
 - [ ] 
 - [ ] 


<hr style='border-width: 3px; border-color:white'/>

> [! info]  [[ journals/$lastweek | Last Week]] | [[journals/$yesterday | Yesterday]] | [[moody/$thedate | Bible]] | [[daily_verse/$thedate | Inspiration]] [[todo/$thedate | ToDo ]] Habits: [ [[Tracker - Habits Daily | Daily ]] [[Tracker - Habits Weekly DV | Weekly  ]]  [[Tracker - Habits Monthly DV | Monthly ]] ] | [[journals/$tomorrow | Tomorrow]] | [[journals/$nextweek | Next Week]]

<hr style='border-width: 6px; border-color:white'/>

#

Entry: **$(date --date="$thedate" +"%F $(date +'%T') CST")**

EOF

echo -e "${header}" > ${journalfile}

todo_rollover
