#!/usr/bin/env bash
# Throttled LinkedIn import for all 🐘😇People notes missing linkedin: frontmatter.
set -euo pipefail

OBSIDIAN="${OBSIDIAN:-$HOME/Documents/notes}"
PEOPLE_DIR="${OBSIDIAN}/people"
BIN="${BIN:-$HOME/bin/parse_li}"
LOG="${LOG:-$HOME/.cache/parse_li_all.log}"
BASE_DELAY="${BASE_DELAY:-180}"
JITTER="${JITTER:-12}"
TAG=$'🐘😇People'
POW=$'🐘POW'

usage() {
    cat <<EOF
Usage: parse_li_all_people

Find high-confidence LinkedIn URLs for people tagged ${TAG} and run
parse_li one person at a time (~${BASE_DELAY}s +/- ${JITTER}s between attempts).

Discovery order: interview URL in note, live postgresql.life page (POW),
then Brave search (single strong name match only).
EOF
}

log() {
    mkdir -p "$(dirname "$LOG")"
    printf '%s %s\n' "$(date -Iseconds)" "$*" | tee -a "$LOG"
}

sleep_jitter() {
    local jitter wait
    jitter=$((RANDOM % (JITTER * 2 + 1) - JITTER))
    wait=$((BASE_DELAY + jitter))
    ((wait < 30)) && wait=30
    log "sleeping ${wait}s (base=${BASE_DELAY}, jitter=${jitter})"
    sleep "$wait"
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
command -v "$BIN" >/dev/null || { echo "parse_li_all_people: missing $BIN" >&2; exit 1; }

mapfile -t PENDING < <(python3 - "$PEOPLE_DIR" "$TAG" "$POW" <<'PY'
import re
import sys
import urllib.parse
import urllib.request
from pathlib import Path

people_dir = Path(sys.argv[1])
tag = sys.argv[2]
pow_tag = sys.argv[3]
LI = re.compile(r"https?://(?:[a-z]{2,3}\.)?linkedin\.com/in/\S+", re.I)
LI_URL = re.compile(r"https?://(?:www\.)?linkedin\.com/in/[A-Za-z0-9_%\-/?]+", re.I)
SLUG = re.compile(r"linkedin\.com/in/([A-Za-z0-9_%\-]+)", re.I)


def parts(text):
    if not text.startswith("---\n"):
        return "", text
    end = text.find("\n---\n", 4)
    return (text[4:end], text[end + 5 :]) if end != -1 else ("", text)


def has_linkedin_fm(fm):
    m = re.search(r"^linkedin:\s*(\S+)", fm, re.M)
    return bool(m and m.group(1).strip() and "linkedin.com" in m.group(1))


def clean_url(u):
    return re.sub(r"\]\(.*$", "", u.rstrip(').,;\'"'))


def slugify(name):
    s = name.strip().lower()
    s = re.sub(r"[^\w\s-]", "", s)
    return re.sub(r"[\s-]+", "_", s)


def tokens(name):
    return [t.lower() for t in re.sub(r"[^A-Za-z0-9\s]", " ", name).split() if len(t) > 1]


def score_match(name, url, company="", title=""):
    toks = tokens(name)
    if len(toks) < 2:
        return 0
    m = SLUG.search(url)
    slug = urllib.parse.unquote(m.group(1)).lower() if m else ""
    blob = (slug + " " + company + " " + title).lower().replace("-", " ")
    if toks[0] not in blob or toks[-1] not in blob:
        return 0
    s = 75 + (15 if all(t in blob for t in toks) else 0)
    if any(k in blob for k in ("postgres", "postgresql", "database", "dba", "engineer", "developer")):
        s += 10
    return s


def brave_search(q):
    url = "https://search.brave.com/search?" + urllib.parse.urlencode({"q": q})
    req = urllib.request.Request(url, headers={"User-Agent": "parse_li_all_people/1.0"})
    with urllib.request.urlopen(req, timeout=30) as r:
        return r.read().decode("utf-8", errors="replace")


def discover(name, fm, body, pow_tagged):
    urls = [clean_url(u) for u in LI.findall(body)]
    if urls:
        return urls[0], "body"

    if pow_tagged:
        slug = slugify(name)
        page_url = f"https://postgresql.life/post/{slug}/"
        try:
            req = urllib.request.Request(page_url, headers={"User-Agent": "parse_pgpow/2.0"})
            with urllib.request.urlopen(req, timeout=25) as r:
                page = r.read().decode("utf-8", errors="replace")
            if "post-container" in page:
                live = [clean_url(u) for u in LI.findall(page)]
                if live:
                    return live[0], "postgresql.life"
        except Exception:
            pass

    company_m = re.search(r"^company:\s*(.*)$", fm, re.M)
    title_m = re.search(r"^title:\s*(.*)$", fm, re.M)
    company = company_m.group(1).strip() if company_m else ""
    title = title_m.group(1).strip() if title_m else ""
    company = re.sub(r"\[\[|\]\]", "", company)

    q = f'"{name}" {company or "PostgreSQL"} linkedin site:linkedin.com/in'
    try:
        html = brave_search(q)
    except Exception as exc:
        return "", f"search_error:{exc}"

    found = list(dict.fromkeys(LI_URL.findall(html)))
    scored = [(score_match(name, u, company, title), u) for u in found[:8]]
    strong = [x for x in scored if x[0] >= 90]
    if len(strong) == 1:
        return strong[0][1], "search"
    if len(strong) > 1:
        return "", "search_ambiguous"
    return "", "search_none"


pending = []
for path in sorted(people_dir.glob("*.md")):
    text = path.read_text(encoding="utf-8", errors="replace")
    fm, body = parts(text)
    if tag not in fm or has_linkedin_fm(fm):
        continue
    pending.append(path.stem)

for name in pending:
    print(name)
PY
)

total=${#PENDING[@]}
log "starting all-people run: ${total} without linkedin frontmatter"
ok=0
fail=0
skip=0

for name in "${PENDING[@]}"; do
    [[ -z "$name" ]] && continue

    note_file="${PEOPLE_DIR}/${name}.md"
    if [[ ! -f "$note_file" ]]; then
        log "skip missing file ${name}"
        ((skip++)) || true
        continue
    fi

    if grep -qE '^linkedin:\s*https?://' "$note_file"; then
        log "skip already linked ${name}"
        ((skip++)) || true
        continue
    fi

    IFS=$'\t' read -r url source < <(python3 - "$note_file" "$name" "$POW" <<'PY'
import re, sys, urllib.parse, urllib.request
from pathlib import Path

path, name, pow_tag = sys.argv[1:4]
text = Path(path).read_text(encoding="utf-8", errors="replace")
LI = re.compile(r"https?://(?:[a-z]{2,3}\.)?linkedin\.com/in/\S+", re.I)
LI_URL = re.compile(r"https?://(?:www\.)?linkedin\.com/in/[A-Za-z0-9_%\-/?]+", re.I)
SLUG = re.compile(r"linkedin\.com/in/([A-Za-z0-9_%\-]+)", re.I)

def parts(text):
    if not text.startswith("---\n"):
        return "", text
    end = text.find("\n---\n", 4)
    return (text[4:end], text[end + 5 :]) if end != -1 else ("", text)

def clean_url(u):
    return re.sub(r"\]\(.*$", "", u.rstrip(').,;\'"'))

def slugify(name):
    s = name.strip().lower()
    s = re.sub(r"[^\w\s-]", "", s)
    return re.sub(r"[\s-]+", "_", s)

def tokens(name):
    return [t.lower() for t in re.sub(r"[^A-Za-z0-9\s]", " ", name).split() if len(t) > 1]

def score_match(name, url, company="", title=""):
    toks = tokens(name)
    if len(toks) < 2: return 0
    m = SLUG.search(url)
    slug = urllib.parse.unquote(m.group(1)).lower() if m else ""
    blob = (slug + " " + company + " " + title).lower().replace("-", " ")
    if toks[0] not in blob or toks[-1] not in blob: return 0
    s = 75 + (15 if all(t in blob for t in toks) else 0)
    if any(k in blob for k in ("postgres", "postgresql", "database", "dba", "engineer", "developer")):
        s += 10
    return s

def brave_search(q):
    url = "https://search.brave.com/search?" + urllib.parse.urlencode({"q": q})
    req = urllib.request.Request(url, headers={"User-Agent": "parse_li_all_people/1.0"})
    with urllib.request.urlopen(req, timeout=30) as r:
        return r.read().decode("utf-8", errors="replace")

fm, body = parts(text)
pow_tagged = pow_tag in fm
urls = [clean_url(u) for u in LI.findall(body)]
if urls:
    print(f"{urls[0]}\tbody")
    raise SystemExit(0)
if pow_tagged:
    slug = slugify(name)
    page_url = f"https://postgresql.life/post/{slug}/"
    try:
        req = urllib.request.Request(page_url, headers={"User-Agent": "parse_pgpow/2.0"})
        with urllib.request.urlopen(req, timeout=25) as r:
            page = r.read().decode("utf-8", errors="replace")
        if "post-container" in page:
            live = [clean_url(u) for u in LI.findall(page)]
            if live:
                print(f"{live[0]}\tpostgresql.life")
                raise SystemExit(0)
    except Exception:
        pass
company_m = re.search(r"^company:\s*(.*)$", fm, re.M)
title_m = re.search(r"^title:\s*(.*)$", fm, re.M)
company = (company_m.group(1).strip() if company_m else "").replace("[[", "").replace("]]", "")
title = title_m.group(1).strip() if title_m else ""
pause = Path("/tmp/parse_li_brave_pause")
if pause.exists():
    import time as _time
    if _time.time() - pause.stat().st_mtime < 3600 and pause.read_text().strip():
        print(f"\tsearch_paused")
        raise SystemExit(0)
    pause.unlink(missing_ok=True)
q = f'"{name}" {company or "PostgreSQL"} linkedin site:linkedin.com/in'
try:
    html = brave_search(q)
    found = list(dict.fromkeys(LI_URL.findall(html)))
    scored = [(score_match(name, u, company, title), u) for u in found[:8]]
    strong = [x for x in scored if x[0] >= 90]
    if len(strong) == 1:
        print(f"{strong[0][1]}\tsearch")
        raise SystemExit(0)
    if len(strong) > 1:
        print(f"\tsearch_ambiguous")
        raise SystemExit(0)
except Exception as exc:
    msg = str(exc)
    if "429" in msg:
        pause.write_text(msg, encoding="utf-8")
    print(f"\tsearch_error:{msg}")
    raise SystemExit(0)
print(f"\tsearch_none")
PY
)

    if [[ -z "$url" || "$url" != http*linkedin.com/in/* ]]; then
        log "no match ${name} (${source:-unknown})"
        ((skip++)) || true
        sleep_jitter
        continue
    fi

    log "processing ${name} (${source}) -> ${url}"
    if OBSIDIAN_PERSON="$name" "$BIN" "$url" >>"$LOG" 2>&1; then
        out=$(tail -1 "$LOG")
        if [[ "$out" == *"/people/${name}.md" ]]; then
            log "OK ${name}"
            ((ok++)) || true
        else
            log "WRONG_FILE ${name} -> ${out}"
            ((fail++)) || true
        fi
    else
        log "FAIL ${name} (exit $?)"
        ((fail++)) || true
    fi
    sleep_jitter
done

log "all-people complete: ok=${ok} fail=${fail} skip=${skip}"
echo "parse_li_all_people: ok=${ok} fail=${fail} skip=${skip} (log: ${LOG})"