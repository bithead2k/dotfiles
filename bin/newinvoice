#!/bin/bash

ScriptVersion="1.0"
business="Newt Global"
contact="Sandeep Rajeev"
duedate=$(date --date="+30 days" +"%Y-%m-%d")
issued=$(date +"%Y-%m-%d")
billrate="95.00"
note="Assignment to AT&amp;T for month of $(date --date="-20 days" +"%B") $(date --date="-20 days" +"%Y")"
quantity=176
vault="/home/kroybal/Documents/notes/"

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options: 
  -b|business name  Company name (default: $business)
  -c|contact  name  Name of contact at business (default: $contact)
  -d|due      date  Date the invoice is receivable (default: $duedate)
  -i|issue    date  Date of invoice (default: $issued today)
  -l|log            Cumulative logging (e.g. -lll)
  -n|note           Description of services (default: $note)
  -q|quantity int   Number of hours to bill (default: $quantity)
  -r|rate     float Dollars per hour (default: $billrate)
  -h|help           Display this message
  -v|version        Display script version

	EOT
}    # ----------  end of function usage  ----------


#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":b:c:d:hi:q:r:v" opt
do
  case $opt in

    b|business )  business="$OPTARG";;

    c|contact  )  contact="$OPTARG";;

    d|due      )  duedate=$(date --date="$OPTARG" +"%Y-%m-%d");;

    h|help     )  usage; exit 0   ;;

    i|issue    ) issued=$(date --date="$OPTARG" +"%Y-%m-%d");;

    l|log      )  (( logging++ )); [[ "$logging" -gt 2 ]] && set -x;;

    n|note     )  note="$OPTARG";;

    q|quantity ) quantity="$OPTARG";;

    r|rate     ) billrate="$OPTARG";;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

#(( total=quantity*billrate ))
total=$(echo "scale=2; $quantity * $billrate" | bc)

invoiceid=$(psql -h localhost -qtAc "INSERT INTO invoices (company, contact, invoice_date) VALUES ('$company','$contact', '$issued') RETURNING id;")

[[ "$logging" -gt 0 ]] && echo "Invoice: $invoiceid Total: \$$total"

#  Use jinja2 to fill in an invoice
cat > ./invoice.json <<-EOF
{
    "date": "$issued",
    "company": "$business",
    "contact": "$contact",
    "invoice": "$invoiceid",
    "amount": "$(printf "$%.2f\n" $billrate)",
    "subtotal": "$(printf "$%.2f\n" $total)",
    "quantity": "$quantity",
    "description": "$note",
    "due": "$duedate"
}
EOF

j2 -f json "${vault}templates/invoice.md" ./invoice.json  > "${vault}invoices/${issued}_${business// /_}_${invoiceid}.md"

[[ -f "./invoice.json" ]] && rm ./invoice.json
