#!/bin/bash
#===============================================================================
#
#          FILE:  new_person
# 
#         USAGE:  ./new_person 
# 
#   DESCRIPTION:  Use the Obsidian API to make a person
#                   using a template
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  03/29/2023 05:09:10 AM CDT
#      REVISION:  ---
#===============================================================================
template=~/"Documents/notes/templates/New Person.md"
newname="${*:-$(xclip -o)}"
first_name=$(echo $newname | cut -d" " -f1)
last_name=$(echo $newname | sed -e "s/^$first_name //")
template=$(cat "${template}" | 
    sed -e "/first_name/s/{{title}}/$first_name/" -e "/last_name/s/{{title}}/$last_name/" |
    sed -e "s/{{date}}/$(date +"%F")/g" -e "s/{{title}}/${newname}/g" \
        -e "/^work_email/s/.*/work_email: ${first_name}.${last_name}@frostbank.com/" )
~/bin/obsidian_cli -naf "people/${newname}" -t "${template}"
