#!/usr/bin/env bash
set -euo pipefail

function osm_company_lookup() {
    local company="$1"

    [[ -z "$company" ]] && return 0

    curl -fsS --get 'https://nominatim.openstreetmap.org/search' \
        --data-urlencode "q=$company" \
        --data-urlencode 'format=jsonv2' \
        --data-urlencode 'addressdetails=1' \
        --data-urlencode 'limit=1' \
        -H 'User-Agent: parse_li/1.0 kirk.roybal@gmail.com'
}

function fetch_linkedin() {
    local url="$1"
    local outfile="$2"
    local ws
    local tab_json
    local tab_id

    curl -fsS http://127.0.0.1:9222/json/version >/dev/null || {
        echo "Start Brave first:" >&2
        echo 'brave-browser --remote-debugging-port=9222 &' >&2
        exit 1
    }

    tab_json="$(
        curl -fsS -X PUT "http://127.0.0.1:9222/json/new?${url}"
    )"

    tab_id="$(jq -r '.id' <<<"$tab_json")"
    ws="$(jq -r '.webSocketDebuggerUrl' <<<"$tab_json")"

    [[ -n "$ws" && "$ws" != "null" ]] || {
        echo "Could not get DevTools websocket URL" >&2
        [[ -n "${tab_id:-}" && "$tab_id" != "null" ]] &&
            curl -fsS "http://127.0.0.1:9222/json/close/${tab_id}" >/dev/null 2>&1 || true
        exit 1
    }

    {
        echo '{"id":1,"method":"Page.enable"}'
        echo '{"id":2,"method":"Runtime.enable"}'
        sleep 3
        # LinkedIn lazy-loads the Experience/Education sections only as they
        # scroll into view.  Incrementally scroll the whole page (re-checking
        # scrollHeight as content grows), then return to the top, before
        # capturing outerHTML.  Without this the DOM contains only the top card.
        echo '{"id":3,"method":"Runtime.evaluate","params":{"awaitPromise":true,"returnByValue":true,"expression":"(async()=>{const s=ms=>new Promise(r=>setTimeout(r,ms));let y=0;for(let i=0;i<30;i++){y+=800;window.scrollTo(0,y);await s(350);if(y>=document.body.scrollHeight){await s(500);if(y>=document.body.scrollHeight)break;}}window.scrollTo(0,0);await s(1000);return document.documentElement.outerHTML;})()"}}'
        sleep 14
    } | websocat -B 20000000 "$ws" |
        tr -d '\000-\010\013\014\016-\037' |
        jq -r 'select(.id==3) | .result.result.value' > "$outfile"

    local rc=$?

    curl -fsS "http://127.0.0.1:9222/json/close/${tab_id}" >/dev/null 2>&1 || true

    [[ $rc -eq 0 ]] || exit "$rc"

    [[ -s "$outfile" ]] || {
        echo "No HTML returned" >&2
        exit 1
    }
}

function ensure_brave_debug() {
    if curl -fsS http://127.0.0.1:9222/json/version >/dev/null 2>&1; then
        return 0
    fi

    echo "Brave is not running with remote debugging." >&2
    echo "Close Brave completely, then start it with:" >&2
    echo >&2
    echo '  brave-browser --remote-debugging-port=9222 --user-data-dir="$HOME/.config/BraveSoftware/Brave-Browser" &' >&2
    echo >&2
    exit 1
}

