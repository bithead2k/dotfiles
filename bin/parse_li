last = parts[-1] if len(parts) > 1 else ""
middle = " ".join(parts[1:-1]) if len(parts) > 2 else ""

def extract_experience_from_dom():
    """
    Pull current employer, current title, and company URL from the FIRST real
    Experience entry in the rendered DOM.  Bounded strictly to the Experience
    section -- LinkedIn marks each section heading with a stable
    "StateCardAnchor_<Section>" anchor -- so editable headline/about/skills
    free text cannot leak in.  Every real position is tied to a /company/<id>/
    page.  Handles both observed card shapes:
        multi-role (company header):  Company / "N yrs M mos" / Role / dates...
        single-role:                  Role / Company [ · Full-time ] / dates...
    Returns (company, title, company_url); any field may be "".
    """
    anchor = re.search(r"StateCardAnchor_Experience", text)
    if not anchor:
        return ("", "", "")
    start = anchor.start()
    nxt = re.search(r"StateCardAnchor_(?!Experience)[A-Za-z]+", text[start + 10:])
    section = text[start: start + 10 + nxt.start()] if nxt else text[start:start + 20000]

    company_url = ""
    cu = re.search(r"https?://[^\"']*?/company/[^\"'/]+/?", section)
    if cu:
        company_url = html.unescape(cu.group(0)).rstrip("/") + "/"

    flat = html.unescape(re.sub(r"<[^>]+>", "\n", section))
    lines = [re.sub(r"\s+", " ", ln).strip() for ln in flat.split("\n")]
    # The section slice begins mid-tag, so the heading token arrives as
    # 'StateCardAnchor_Experience">Experience'.  Strip the anchor-attribute
    # prefix so the real heading/first line is recovered.
    lines = [re.sub(r'^.*?StateCardAnchor_\w+"?>?', "", ln).strip() for ln in lines]
    lines = [ln for ln in lines if ln]
    if lines and lines[0].casefold() == "experience":
        lines = lines[1:]
    if not lines:
        return ("", "", company_url)

    tenure = re.compile(r"^\d+\s*yrs?(\s+\d+\s*mos?)?$|^\d+\s*mos?$", re.I)
    datey = re.compile(
        r"\b(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Sept|Oct|Nov|Dec)\b|\bPresent\b", re.I
    )
    locish = re.compile(r"(United States|Remote|On-site|On site|Hybrid|Greater|Area|·)", re.I)
    emptype = re.compile(
        r"^(Full-time|Part-time|Contract|Self-employed|Freelance|Internship|"
        r"Temporary|Apprenticeship)$", re.I
    )

    company = ""
    title = ""
    if len(lines) >= 2 and tenure.match(lines[1]):
        # Multi-role company-header card: company first, then tenure, then roles.
        company = lines[0]
        for cand in lines[2:7]:
            if tenure.match(cand) or datey.search(cand) or locish.search(cand):
                continue
            if emptype.match(cand) or experience_stop_line(cand):
                continue
            title = cand
            break
    else:
        # Single-role card: title first, then company (optionally "· Full-time").
        title = lines[0]
        company = lines[1] if len(lines) >= 2 else ""

    company = clean_company_candidate(company)
    company = re.sub(r"\s+\d+\s*yrs?(\s+\d+\s*mos?)?$", "", company, flags=re.I).strip()
    return (company.strip(), title.strip(), company_url)

exp_company, exp_title, company_url = extract_experience_from_dom()

title = exp_title
