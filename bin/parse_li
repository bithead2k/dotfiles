def visible_lines(fragment):
    fragment = re.sub(r"<script.*?</script>", " ", fragment, flags=re.I | re.S)
    fragment = re.sub(r"<style.*?</style>", " ", fragment, flags=re.I | re.S)
    fragment = re.sub(r"<svg.*?</svg>", " ", fragment, flags=re.I | re.S)
    fragment = re.sub(r"<[^>]+>", "\n", fragment)
    fragment = html.unescape(fragment)

    lines = []
    for line in fragment.splitlines():
        line = re.sub(r"\s+", " ", line).strip()
        if line:
            lines.append(line)
    return lines


def looks_like_person_location(line):
    if not line:
        return False

    bad = {
        name,
        title,
        company,
        f"{title} at {company}",
        "More",
        "Message",
        "Contact info",
    }

    if line in bad:
        return False

    if len(line) > 120:
        return False

    # Common LinkedIn location formats:
    # Boston, Massachusetts, United States
    # Dallas-Fort Worth Metroplex
    # Greater Chicago Area
    # Toronto, Ontario, Canada
    # London, England, United Kingdom
    patterns = [
        r"^[A-Z][A-Za-z .'-]+,\s*[A-Z][A-Za-z .'-]+,\s*[A-Z][A-Za-z .'-]+$",
        r"^[A-Z][A-Za-z .'-]+,\s*[A-Z][A-Za-z .'-]+$",
        r"\bMetroplex\b",
        r"\bMetropolitan Area\b",
        r"^Greater .+ Area$",
    ]

    return any(re.search(p, line) for p in patterns)



headline = f"{title} at {company}" if title and company else title
anchor_pos = text.find(headline)

if anchor_pos < 0 and title:
    anchor_pos = text.find(title)

if anchor_pos < 0:
    anchor_pos = text.find(name)

if anchor_pos >= 0:
    window = text[anchor_pos:anchor_pos + 50000]
    lines = visible_lines(window)

    for line in lines[:120]:
        if looks_like_person_location(line):
            person_location = line
            break

if company and person_location:
    company_location_query = f"{company} {person_location}"
    company_location_url = (
        "https://www.google.com/maps/search/"
        + urllib.parse.quote_plus(company_location_query)
    )

if company_location_url:
    maps_html = devtools_fetch(company_location_url)
    maps_text = html.unescape(maps_html)

    # Debug while testing
    Path("/tmp/google_maps.txt").write_text(maps_text)
    # print("DEBUG saved Google Maps text to /tmp/google_maps.txt")
    # print(f"DEBUG maps_text length={len(maps_text)}")
    # Path("/tmp/google_maps.html").write_text(maps_html)
    # Look for US address shape:
    # 501 Boylston St 3rd Floor, Boston, MA 02116
    m = re.search(
        r'(\d{1,6}\s+[A-Za-z0-9 .\'-]+?(?:St|Street|Ave|Avenue|Rd|Road|Blvd|Boulevard|Dr|Drive|Ln|Lane|Way|Pl|Place|Pkwy|Parkway|Trail|Tr|Circle|County Rd|County Road|CR)(?:[^\n,]*?)?)'
        r'(?:,|\n|\s{2,})\s*'
        r'([A-Z][A-Za-z .\'-]+)'
        r'(?:,|\n|\s{2,})\s*'
        r'([A-Z]{2})\s+'
        r'(\d{5}(?:-\d{4})?)',
        maps_text,
        re.I,
    )

    if m:
        maps_street = re.sub(r"\s+", " ", m.group(1)).strip()
        maps_city = re.sub(r"\s+", " ", m.group(2)).strip()
        maps_state = m.group(3).strip()
        maps_zip = m.group(4).strip()
        maps_country = "United States"

    p = re.search(
        r'(\(\d{3}\)\s*\d{3}-\d{4})',
        maps_text
    )

    if p:
        company_phone = p.group(1)


NICKNAME_CANON = {
    "zac": "zachary",
    "zach": "zachary",
    "zack": "zachary",
    "zachary": "zachary",
    "bill": "william",
    "billy": "william",
    "will": "william",
    "william": "william",
    "bob": "robert",
    "bobby": "robert",
    "rob": "robert",
    "robert": "robert",
    "jim": "james",
    "jimmy": "james",
    "james": "james",
    "mike": "michael",
    "michael": "michael",
    "dave": "david",
    "david": "david",
    "tom": "thomas",
    "tommy": "thomas",
    "thomas": "thomas",
    "johnny": "john",
    "john": "john",
}


def name_tokens(value):
    return re.findall(r"[a-z0-9]+", yaml_scalar(value).casefold())


def canon_first(value):
    toks = name_tokens(value)
    if not toks:
        return ""
    return NICKNAME_CANON.get(toks[0], toks[0])


def edit_distance_leq_one(a, b):
    a = yaml_scalar(a).casefold()
    b = yaml_scalar(b).casefold()
    if a == b:
        return True
    if abs(len(a) - len(b)) > 1:
        return False
    i = j = edits = 0
    while i < len(a) and j < len(b):
        if a[i] == b[j]:
            i += 1
            j += 1
            continue
        edits += 1
        if edits > 1:
            return False
        if len(a) == len(b):
            i += 1
            j += 1
        elif len(a) > len(b):
            i += 1
        else:
            j += 1
    if i < len(a) or j < len(b):
        edits += 1
    return edits <= 1


def name_match_score(profile_name, candidate_name):
    pt = name_tokens(profile_name)
    ct = name_tokens(candidate_name)
    if not pt or not ct:
        return 0

    pf = canon_first(profile_name)
    cf = canon_first(candidate_name)
    pl = pt[-1]
    cl = ct[-1]

    score = 0
    if pf and cf and pf == cf:
        score += 60
    elif pt[0] == ct[0]:
        score += 45
    else:
        return 0

    if pl == cl:
        score += 60
    elif edit_distance_leq_one(pl, cl):
        score += 50
    else:
        return 0

    # Prefer fuller canonical names when LinkedIn uses a short form.
    if len(ct) > len(pt):
        score += 5

    return score


def candidate_names_from_frontmatter(path, data):
    names = [path.stem]

    fm_name = " ".join(
        yaml_scalar(data.get(k, ""))
        for k in ("first_name", "middle_name", "last_name")
        if yaml_scalar(data.get(k, ""))
    ).strip()
    if fm_name:
        names.append(fm_name)

    for alias in split_alias_values(data.get("aliases", "")):
        names.append(alias)

    # Existing LinkedIn slug can also identify a page on repeat runs.
    existing_slug = yaml_scalar(data.get("linkedin_slug", ""))
    if existing_slug:
        names.append(existing_slug.replace("-", " "))

    cleaned = []
    for n in names:
        n = re.sub(r"\s+", " ", yaml_scalar(n)).strip()
        if n and n not in cleaned:
            cleaned.append(n)
    return cleaned


def resolve_people_page(profile_name, profile_slug, people_dir):
    safe = re.sub(r'[\\/:*?"<>|]', '', profile_name).strip()
    direct = people_dir / f"{safe}.md"

    profile_key = normalize_alias_key(profile_name)

    # Highest-priority resolver:
    #   If any existing people page has aliases containing the exact LinkedIn
    #   display name, use that page.  This is explicit user-maintained identity
    #   data and beats direct filename creation and fuzzy matching.
    alias_hits = []
    if people_dir.exists() and profile_key:
        for path in people_dir.glob("*.md"):
            if path.name.startswith("."):
                continue
            try:
                data, _order, _body = parse_frontmatter(path.read_text(errors="ignore"))
            except Exception:
                data = {}

            for alias in split_alias_values(data.get("aliases", "")):
                if normalize_alias_key(alias) == profile_key:
                    alias_hits.append((path, alias))
                    break

    if len(alias_hits) == 1:
        path, alias = alias_hits[0]
        print(f"Resolved LinkedIn profile {profile_name!r} to existing page {path} (exact aliases match {alias!r})")
        return path, f"exact aliases match {alias!r}"

    if len(alias_hits) > 1:
        print("Ambiguous exact alias matches for LinkedIn profile:", file=sys.stderr)
        for path, alias in alias_hits:
            print(f"  {path} aliases: {alias!r}", file=sys.stderr)
        raise SystemExit("Refusing to choose between duplicate exact aliases.")

    # Repeat-run URL/slug resolver.  This also beats direct filename creation.
    # If the exact LinkedIn URL or slug is already on a people page, use it.
    url_hits = []
    if people_dir.exists():
        for path in people_dir.glob("*.md"):
            if path.name.startswith("."):
                continue
            try:
                data, _order, _body = parse_frontmatter(path.read_text(errors="ignore"))
            except Exception:
                data = {}

            existing_slug = yaml_scalar(data.get("linkedin_slug", ""))
            existing_url = yaml_scalar(data.get("linkedin", ""))
            if profile_slug and existing_slug and profile_slug == existing_slug:
                url_hits.append((path, "same linkedin_slug"))
            elif profile_url and existing_url and profile_url.rstrip("/") == existing_url.rstrip("/"):
                url_hits.append((path, "same linkedin URL"))

    unique_url_hits = []
    seen_paths = set()
    for path, why in url_hits:
        if path in seen_paths:
            continue
        unique_url_hits.append((path, why))
        seen_paths.add(path)

    if len(unique_url_hits) == 1:
        path, why = unique_url_hits[0]
        print(f"Resolved LinkedIn profile {profile_name!r} to existing page {path} ({why})")
        return path, why

    if len(unique_url_hits) > 1:
        print("Ambiguous LinkedIn URL/slug matches:", file=sys.stderr)
        for path, why in unique_url_hits:
            print(f"  {path} ({why})", file=sys.stderr)
        raise SystemExit("Refusing to choose between duplicate LinkedIn URL/slug matches.")

    # If the LinkedIn display-name file already exists, use it.
    if direct.exists():
        return direct, "direct LinkedIn display-name match"

    # Last resort: fuzzy/nickname resolver for cases without explicit aliases.
    best = []
    if people_dir.exists():
        for path in people_dir.glob("*.md"):
            if path.name.startswith("."):
                continue
            try:
                data, _order, _body = parse_frontmatter(path.read_text(errors="ignore"))
            except Exception:
                data = {}

            score = 0
            why = []

            # Fuzzy matching may consider filename/frontmatter/aliases, but exact
            # alias matching above is the authoritative alias path.
            for cand in candidate_names_from_frontmatter(path, data):
                s = name_match_score(profile_name, cand)
                if s > score:
                    score = s
                    why = [f"name match {cand!r}"]

            if score >= 100:
                best.append((score, path, ", ".join(why) or "matched"))

    best.sort(key=lambda x: x[0], reverse=True)
    if len(best) == 1 or (len(best) > 1 and best[0][0] - best[1][0] >= 20):
        print(f"Resolved LinkedIn profile {profile_name!r} to existing page {best[0][1]} ({best[0][2]}, score={best[0][0]})")
        return best[0][1], best[0][2]

    if best:
        print("Ambiguous existing people-page matches for LinkedIn profile:", file=sys.stderr)
        for score, path, why in best[:8]:
            print(f"  score={score} {path} ({why})", file=sys.stderr)
        raise SystemExit("Refusing to choose an ambiguous people page.")

    return direct, "new page from LinkedIn display name"


people_dir = Path(obsidian) / "people"
outfile, outfile_reason = resolve_people_page(name, slug, people_dir)
safe_name = outfile.stem

if not safe_name:
    raise SystemExit("Could not determine safe filename; refusing to create Unknown.md")

outfile.parent.mkdir(
    parents=True,
    exist_ok=True
)

assets_dir = Path(obsidian) / "people" / "assets"
