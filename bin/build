#!/bin/bash - 
#===============================================================================
#
#          FILE: build
# 
#         USAGE: ./build 
# 
#   DESCRIPTION: 
# 
#       OPTIONS: ---
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (), kirk.roybal@2ndquadrant.com
#  ORGANIZATION: 
#       CREATED: 08/17/2017 08:43
#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error
 
set -x

[[ -d "img" ]] || mkdir img
[[ -d "cache" ]] || mkdir cache

# process all of the graphviz nodes
for png in *.dot
do
	dot -Tpng "$png" > "img/${png/%dot/png}"
done

for png in *.circo
do
    circo -Tpng "$png" > "img/${png/%dot/png}"
done
for png in *.fdp
do
	fdp -Tpng "$png" > "img/${png/%dot/png}"
done
make
