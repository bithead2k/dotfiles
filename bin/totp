#!/bin/bash
#===============================================================================
#
#          FILE:  totp
# 
#         USAGE:  ./totp 
# 
#   DESCRIPTION:  Find a key for a service and generate a one-time token
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  Files are located in ~/.2fa/gauth.totp.keys
#       Tokens were extracted by zbarimg 
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  08/04/2022 08:18:55 AM CDT
#      REVISION:  ---
#===============================================================================

ScriptVersion="1.0"
debug=0
twofa_dir=~/.config/2fa/


[[ -d ${twofa_dir} ]] || mkdir -p ${twofa_dir}

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options: 
  -d|debug          Cumulative debugging flag (e.g. -ddd)
  -h|help           Display this message
  -l|list           List the available services
  -p|print [token]  Show the full otpauth URL for the service
  -s|secret [token] Show the secret key for the service
  -t|token [token]  Show a TOTP for the service (default)
  -v|version        Display script version

	EOT
}    # ----------  end of function usage  ----------

#===  FUNCTION  ================================================================
#          NAME:  list_tokens
#   DESCRIPTION:  Get a list of the token names and show it to the user
#    PARAMETERS:  none
#       RETURNS:  Sorted list of token file names
#===============================================================================
function list_tokens(){
    
    local line

    for line in $(cat ${twofa_dir}gauth.totp.keys 2>&1 | 
        sed -e 's_^otpauth://totp/__' -e 's/?.*$//')
    do
        urldecode "$line"
    done | sort | uniq

}

function print_token(){

    local line

    for line in $(cat ${twofa_dir}gauth.totp.keys 2>&1 | 
        sed -e 's_^otpauth://totp/__' ) #-e 's/?.*$//')
    do
        urldecode "$line"
    done | grep "$1" | tail -n1  # <-- 'timescale' is not unique

}

function print_secret(){

    print_token "$1" | sed -e 's/^.*secret=//'

}

function print_totp(){

    local secret="$(print_secret $@)"
    [[ $debug -gt 2 ]] && echo "totp secret: $secret"
    oathtool -b --totp "$secret"

}

function clipboard(){
    
    tee /dev/tty | xclip -selection clipboard

}

# quick and dirty, no unicode
function urldecode() { : "${*//+/ }"; echo -e "${_//%/\\x}"; }

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------
arguments="$@"

while getopts ":dhlp:s:t:v" opt
do
  case $opt in

    d|debug    )  (( debug++ )) ; [[ $debug -gt 1 ]] && set -x ;;

    h|help     )  usage; exit 0   ;;

    l|list     )  list_tokens ; exit 0 ;;

    p|print    )  print_token "$OPTARG" ; exit 0 ;;

    s|secret   )  print_secret "$OPTARG" ; exit 0 ;;

    t|token    )  print_totp "$OPTARG" | clipboard ; exit 0 ;;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

[[ $debug -gt 0 ]] && echo "$arguments"
[[ $debug -gt 0 ]] && echo "Arg Count: $#"

[[ $# -eq 0 ]] && usage && exit 0

# default to print the totp for whatever is on the command line
[[ $debug -gt 1 ]] && print_token "$arguments"
[[ $debug -gt 0 ]] && print_secret "$arguments"
print_totp "$arguments" | clipboard
