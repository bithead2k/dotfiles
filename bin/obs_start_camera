# Press the button in OBS
xdotool search --name '^OBS Studio .+$' windowactivate --sync key ctrl+shift+C
sleep 2
xdotool keydown Shift key h keyup Shift key o key p key l key o key p key h key o key b key e key 1 key 'exclam' Return
