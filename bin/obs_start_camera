#!/bin/bash
#===============================================================================
#
#          FILE:  obs_start_camera
# 
#         USAGE:  ./obs_start_camera 
# 
#   DESCRIPTION:  Start the virtual camera
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
