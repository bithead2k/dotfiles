set -o nounset                              # Treat unset variables as an error

die () {

    echo $1
    exit 1
}


function usage() {

   echo "$0 group [--set|--list] [variant] " 

}

case $2 in
    --set | set)
        sudo port select $1 $3
        ;;
    *)
        usage
        die "unimplemented: $2"
        ;;
esac
