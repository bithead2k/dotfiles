#!/usr/bin/env bash
# Add PostgreSQL Person of the Week interview content to a people note.
set -euo pipefail

person="${*:-$(xclip -o 2>/dev/null | head -1)}"
[[ -z "$person" ]] && { echo "obsidian_add_pow: provide a name" >&2; exit 1; }

pow=$(pg_pow --markdown "$person")
obsidian_cli -naf "people/${person}" -t "${pow}"