#!/bin/bash
#===============================================================================
#
#          FILE:  photon
# 
#         USAGE:  ./photon 
# 
#   DESCRIPTION:  Data collector for Photon app
# 
#       https://docs.google.com/document/d/1vOYUKQJ5jgqODy3fcNNGsKMsZkGTsqqqb3DdGbRFJxM
#
#       OPTIONS:  ---
#  REQUIREMENTS:  jq
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  10/25/2022 04:25:26 AM CDT
#      REVISION:  ---
#===============================================================================

# Globals
psql_connect=""
photon_device="3f002f000347313134313535"
ScriptVersion="1.0"
logging=0

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  e.g.:
  ${0##/*/} -d 3f002f000347313134313535 -c 'postgres://username:password@localhost:5432?dbname=metrics'

  Options: 
  -c|connect [string]  Connect parameters for psql
  -d|device  [string]  Id of the photon device
  -l|log               Cumulatively verbose logging (e.g. -lll)
  -h|help              Display this message
  -v|version           Display script version

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":hc:d:lv" opt
do
  case $opt in

    c|connect  )  psql_connect="$OPTARG";;

    d|device   )  photon_device="$OPTARG";;

    h|help     )  usage; exit 0   ;;

    l|log      ) (( logging++ )) ;;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

# if the debug flag is high enough, turn on bash debugging
[[ $logging -gt 2 ]] && set -x

which jq >/dev/null || {
    echo -e "jq is not installed.\nTry: \n\tsudo apt -y install jq"
    exit
}

while read -r line; do
    data=$(echo ${line} | jq '.data | tonumber' 2>/dev/null)
    ts=$(echo ${line} | jq .published_at 2>/dev/null)
   if [ -z ${data} ]; then
       continue;
   fi
   if [ -z ${ts} ]; then
       continue;
   fi
   echo "sending data: ${data} and ts: ${ts}"
   insert="insert into light (time,light) values ('${ts}', ${data});"
   psql $psql_connect -qtAc "${insert}"
done < <(particle subscribe --device $photon_device -q)
