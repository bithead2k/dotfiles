#!/bin/bash - 
#===============================================================================
#
#          FILE: primary_config
# 
#         USAGE: ./primary_config 
# 
#   DESCRIPTION: 
# 
#       OPTIONS: ---
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (KLR), kroybal@tripadvisor.com
