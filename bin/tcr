set -x

function get_chain_html() {
	for letter in {a..z}
	do 
	    # Find out how many pages of references are in letter
	    wget https://www.studylight.org/concordances/eng/tcr/${letter}.html -O ${letter}-01.html
	    pages=$(cat ${letter}-01.html | grep pagination | tail -n 1 | sed 's/.*pn=//' | sed 's/&.*$//')
	    cat ${letter}-01.html | grep "<a href=\"/concordances/eng/tcr/${letter}/" > ${letter}-chains.lst
        rm ${letter}-01.html
	    for (( page=2;page<=$pages;page++))
	    do
	        wget https://www.studylight.org/concordances/eng/tcr/${letter}.html?pn=${page} -O ${letter}-0${page}.html
	        cat ${letter}-0${page}.html | grep "<a href=\"/concordances/eng/tcr/${letter}/" >> ${letter}-chains.lst
	        rm ${letter}-0${page}.html
	    done
	done
}

function get_chain_references{
    prefix="https://www.studylight.org"
    for letter in {a..z}
    do
        chain=$(cat ${letter}-chains.lst | 
    done
}

# get_chain_html

get_chain_references


