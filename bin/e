set -o nounset                              # Treat unset variables as an error

function die(){
	retval=$1
	shift
	echo "$@"
	exit $retval
}

script=~/bin/${1:-e}

[[ -f $script ]] || {
	echo "#!$SHELL" > $script
	chmod +x $script
}

gvim $script
