#!/bin/bash
#===============================================================================
#
#          FILE: newpassword
# 
#         USAGE: ./newpassword 
# 
#   DESCRIPTION: Use a diceware password generator 
#       to create human "rememberable" passwords.
# 
#       OPTIONS: ---
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (), kirk.roybal@2ndquadrant.com
#  ORGANIZATION: 
#       CREATED: 09/16/2019 10:27
#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error



ScriptVersion="1.0"
password_length=6
use_uppercase=false
use_numbers=false
random_sep=false

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options: 
  -d|debug      Display bash debugging info
  -h|help       Display this message
  -n|numbers    Use numeric digits
  -r|refresh    Reload the function from file
  -s|seperator  Randomize the seperator between words
  -u|ucase      Use captial letters
  -v|version    Display script version
  -w|words  [n] Number of words in password

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":dhnrsuvw:" opt
do
  case $opt in

    d|debug    )  set -x;;

    h|help     )  usage; exit 0   ;;

    n|numbers  )  use_numbers='true';;

    r|refresh  )  [[ -f password_diceware.sql ]] && psql -qtAf password_diceware.sql > /dev/null;;

    s|seperator)  random_sep='true';;

    u|ucase    )  use_uppercase='true';;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    w|words    )  password_length=$OPTARG;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

sql="SELECT password_diceware($password_length, $use_uppercase, $use_numbers,$random_sep);"
newpwd=$(psql -qtAc "${sql}")
echo -n $newpwd | xclip -selection clipboard
echo $newpwd

