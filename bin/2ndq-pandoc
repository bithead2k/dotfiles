#!/usr/bin/env bash
set -eu
set -o pipefail

usage () {
    cat <<EOF
Syntax:

        2ndq-pandoc SOURCEFILE [OPTION [OPTION [...]]]

Where each OPTION can be one of the following:

	--template TEMPLATE

		Uses the given template. If TEMPLATE includes the
		character '/', then it is interpreted as a relative
		path. Otherwise, it is assumed to be in Pandoc's
		template directory.

The other options are passed unchanged to Pandoc. See Pandoc's
documentation for more information on all available options.

EOF
}

Opts=""

if [[ $? -ne 0 ]]; then
    usage
    exit 1
fi

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

TemplateFileName=2ndQuadrantReport

Source="$1"

Target="${Source%.md}.pdf"

shift

is_html=false

while true; do
    case "${1:-}" in
    '--html')
        is_html=true
        Target="${Source%.md}.html"
        shift
        continue
        ;;
    '--debug')
        set -x
        shift
        continue
        ;;
	'--template')
	    TemplateFileName="$2"
	    shift 2
	    continue
	    ;;
	'--listings')
	    Opts="$Opts $1"
	    shift 1
	    continue
	    ;;
	'--filter')
	    Opts="$Opts $1 $2"
	    shift 2
	    continue
	    ;;
	'--')
	    shift
	    break
	    ;;
    '')
        break
        ;;
	*)
	    usage
	    exit 1
	    ;;
    esac
done


if hash greadlink 2>/dev/null; then
    DataDir=$(cd "$(dirname "$(greadlink -f "$0")")" && pwd)
else
    DataDir=$(cd "$(dirname "$(readlink -f "$0")")" && pwd)
fi

if [[ "${TemplateFileName////}" = "$TemplateFileName" ]]; then
    TemplateFile=$DataDir/templates/$TemplateFileName.latex
    MetadataFile=$DataDir/templates/$TemplateFileName.yaml
else
    TemplateFile=$TemplateFileName
    MetadataFile=${TemplateFileName%.latex}.yaml
fi

if [[ ! -f $TemplateFile ]]; then
    cat <<EOF
ERROR: template files not found:

	$TemplateFile
	$MetadataFile

Please check command line arguments.

EOF
    exit 2
fi

# Kirk L. Roybal: Added the date macros here.
#  If you don't want magic dates, they can
#  still be overridden in the header section:
#  date: 2020-02-13
#  copyright-years: 2018-20
pandoc -s \
       --template=$TemplateFile \
       --variable author="Kirk L. Roybal" \
       --variable date="$(date +'%Y-%m-%d')" \
       --variable copyright-years="$(date +'%Y')" \
       --data-dir=$DataDir \
       --metadata=datadir:$DataDir \
       -o "$Target" $Opts \
       "$Source" $MetadataFile

[[ $is_html == 'true' ]] && {

    header=$(grep -n  "%END 2ndQuadrant" "$Target" | 
      tail -n 1 | sed 's/^\([[:digit:]]*\).*/\1/')
    sed -i "$Target" -e "1,${header}d" -e '$d'
    sed -i "$Target" -e "1i\<html><head><Title>$Target</Title></head><body>"
    sed -i "$Target" -e "\$i\</body></html>"

}
