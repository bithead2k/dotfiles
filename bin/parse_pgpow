#!/usr/bin/env bash
# parse_pgpow: postgresql.life Person of the Week → surgical Obsidian people importer
# Fetches interviews from RSS/archive; fills blanks only (same family as parse_li / parse_bv).
set -euo pipefail

OBSIDIAN="${OBSIDIAN:-$HOME/Documents/notes}"
PEOPLE_DIR="${OBSIDIAN}/people"
TEMPLATE="${TEMPLATE:-${OBSIDIAN}/templates/New Person.md}"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
LOG_FILE="${CACHE_DIR}/parse_pgpow.log"
RSS_URL="https://postgresql.life/index.xml"
INTERVIEWS_URL="https://postgresql.life/categories/interviews/"
POW_TAG=$'🐘POW'

usage() {
    cat <<'EOF'
Usage: parse_pgpow [options] [name-or-slug]

Fetch a PostgreSQL Person of the Week interview from postgresql.life and
create or update a people note in the Obsidian vault.

Options:
  --latest       Use the newest RSS entry (for cron; skips if note exists)
  --backfill     Walk the full interview archive; surgically create or update
                 notes (tags, image, interview) without overwriting populated fields
  --markdown     Print note body to stdout (image + interview); no vault write
  --open         Open the note in Obsidian after creating (default for manual use)
  --quiet        No Obsidian URI; log only (implied by --latest and --backfill)
  -h, --help     Show this help

With no arguments, reads a name from the clipboard (xclip).
EOF
}

log() {
    mkdir -p "$(dirname "$LOG_FILE")"
    printf '%s parse_pgpow: %s\n' "$(date -Iseconds)" "$*" >>"$LOG_FILE"
}

resolve_person() {
    local query="${1:-}"
    python3 - "$query" "$RSS_URL" <<'PY'
import re
import sys
import urllib.request

query, rss_url = sys.argv[1], sys.argv[2]

def fetch(url):
    req = urllib.request.Request(url, headers={"User-Agent": "parse_pgpow/2.0"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        return resp.read().decode("utf-8")

def slugify(name):
    s = name.strip().lower()
    s = re.sub(r"[^\w\s-]", "", s, flags=re.UNICODE)
    return re.sub(r"[\s-]+", "_", s)

def resolve_slug(slug):
    url = f"https://postgresql.life/post/{slug}/"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "parse_pgpow/2.0"})
        with urllib.request.urlopen(req, timeout=30) as resp:
            if resp.status != 200:
                return None
            page = resp.read().decode("utf-8", errors="replace")
            if "post-container" not in page:
                return None
            title_m = re.search(r"<h1>([^<]+)</h1>", page)
            title = title_m.group(1).strip() if title_m else slug.replace("_", " ").title()
            return title, slug, url
    except Exception:
        return None

items = []
for block in re.findall(r"<item>(.*?)</item>", fetch(rss_url), re.DOTALL):
    title_m = re.search(r"<title>([^<]+)</title>", block)
    link_m = re.search(r"<link>([^<]+)</link>", block)
    if title_m and link_m:
        link = link_m.group(1).strip()
        slug = link.rstrip("/").split("/")[-1]
        items.append((title_m.group(1).strip(), slug, link))

if not items:
    raise SystemExit("parse_pgpow: no interviews in RSS feed")

if not query or query == "--latest":
    title, slug, link = items[0]
    print(f"{title}\t{slug}\t{link}")
    raise SystemExit(0)

q = query.strip()
q_slug = slugify(q)
slug_candidates = []
for candidate in (q.lower().replace(" ", "_"), q_slug, re.sub(r"[\s-]+", "_", q.lower())):
    if candidate and candidate not in slug_candidates:
        slug_candidates.append(candidate)

for title, slug, link in items:
    if q.lower() == title.lower() or q_slug == slug or q.lower().replace(" ", "_") == slug:
        print(f"{title}\t{slug}\t{link}")
        raise SystemExit(0)

for candidate in slug_candidates:
    resolved = resolve_slug(candidate)
    if resolved:
        title, slug, link = resolved
        print(f"{title}\t{slug}\t{link}")
        raise SystemExit(0)

names = ", ".join(t for t, _, _ in items[:5])
raise SystemExit(f"parse_pgpow: no match for {query!r} (recent: {names})")
PY
}

list_interviews() {
    python3 - "$INTERVIEWS_URL" <<'PY'
import re
import sys
import urllib.request

url = sys.argv[1]

def fetch(target):
    req = urllib.request.Request(target, headers={"User-Agent": "parse_pgpow/2.0"})
    with urllib.request.urlopen(req, timeout=60) as resp:
        return resp.read().decode("utf-8", errors="replace")

html = fetch(url)
slugs = []
seen = set()
for slug in re.findall(r"/post/([\w_]+)/", html):
    if slug == "postgresql_person_of_the_week" or slug in seen:
        continue
    seen.add(slug)
    slugs.append(slug)

for slug in slugs:
    print(f"https://postgresql.life/post/{slug}/")
PY
}

fetch_markdown() {
    local link="$1"
    python3 - "$link" <<'PY'
import html
import re
import sys
import urllib.request
from html.parser import HTMLParser

link = sys.argv[1]
base = link if link.endswith("/") else link + "/"

def fetch(url):
    req = urllib.request.Request(url, headers={"User-Agent": "parse_pgpow/2.0"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        return resp.read().decode("utf-8", errors="replace")

def head_ok(url):
    req = urllib.request.Request(url, method="HEAD", headers={"User-Agent": "parse_pgpow/2.0"})
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return 200 <= resp.status < 400
    except Exception:
        return False

def resolve_image(slug, page):
    og_m = re.search(r'property="og:image:url" content="([^"]+)"', page)
    candidates = []
    if og_m:
        candidates.append(og_m.group(1))
    candidates.extend(
        [
            f"https://postgresql.life/images/posts/{slug}_600.jpg",
            f"https://postgresql.life/post/{slug}/{slug}_600.jpg",
            f"https://postgresql.life/post/{slug}/{slug}.jpg",
        ]
    )
    seen = set()
    for url in candidates:
        if url in seen:
            continue
        seen.add(url)
        if head_ok(url):
            return url
    return candidates[0]

class ToMarkdown(HTMLParser):
    def __init__(self, base_url):
        super().__init__(convert_charrefs=True)
        self.base = base_url
        self.parts = []
        self.link_stack = []
        self.skip = 0

    def handle_starttag(self, tag, attrs):
        attrs = dict(attrs)
        if self.skip:
            self.skip += 1
            return
        if tag in ("script", "style"):
            self.skip = 1
            return
        if tag == "h3":
            self._break()
            self.parts.append("### ")
        elif tag == "h4":
            self._break()
            self.parts.append("#### ")
        elif tag == "p":
            self._break()
        elif tag == "br":
            self.parts.append("\n")
        elif tag == "li":
            self._break()
            self.parts.append("-   ")
        elif tag == "a":
            href = attrs.get("href") or ""
            if href.startswith("/"):
                href = "https://postgresql.life" + href
            elif href and not href.startswith(("http://", "https://", "mailto:")):
                href = self.base + href.lstrip("/")
            self.link_stack.append(href)
            self.parts.append("[")
        elif tag == "img":
            src = attrs.get("src") or ""
            alt = attrs.get("alt") or ""
            if src.startswith("/"):
                src = "https://postgresql.life" + src
            elif src and not src.startswith("http"):
                src = self.base + src.lstrip("/")
            self.parts.append(f"![{alt}]({src})")
        elif tag == "figcaption":
            self._break()
            self.parts.append("#### ")

    def handle_endtag(self, tag):
        if self.skip:
            self.skip -= 1
            return
        if tag in ("h3", "h4", "figcaption"):
            self.parts.append("\n\n")
        elif tag == "p":
            self.parts.append("\n\n")
        elif tag == "li":
            self.parts.append("\n")
        elif tag == "a":
            if self.link_stack:
                href = self.link_stack.pop()
                self.parts.append(f"]({href})")

    def handle_data(self, data):
        if not self.skip:
            self.parts.append(data)

    def _break(self):
        if self.parts and not self.parts[-1].endswith("\n"):
            self.parts.append("\n")

    def get_markdown(self):
        text = "".join(self.parts)
        text = html.unescape(text)
        text = re.sub(r"\n{3,}", "\n\n", text)
        return text.strip()

page = fetch(link)
title_m = re.search(r"<h1>([^<]+)</h1>", page)
title = title_m.group(1).strip() if title_m else ""
slug = link.rstrip("/").split("/")[-1]
image = resolve_image(slug, page)

m = re.search(
    r"<div class=post-container>(.*?)</div>\s*<br><br>\s*<a class=resp-sharing",
    page,
    re.DOTALL,
)
if not m:
    m = re.search(r"<div class=post-container>(.*?)</div>", page, re.DOTALL)
container = m.group(1) if m else ""

parser = ToMarkdown(base)
parser.feed(container)
body = parser.get_markdown()

print(f"TITLE:{title}")
print(f"IMAGE:{image}")
print("BODY:")
print(body)
PY
}

parse_fetched() {
    local parsed="$1"
    PARSED_TITLE=$(printf '%s\n' "$parsed" | sed -n 's/^TITLE://p' | head -1)
    PARSED_IMAGE=$(printf '%s\n' "$parsed" | sed -n 's/^IMAGE://p' | head -1)
    PARSED_BODY=$(printf '%s\n' "$parsed" | awk 'found{print} /^BODY:$/{found=1}')
}

apply_pow_note() {
    local mode="$1" person_name="$2" person_link="$3" image="$4"
    local interview_file note_file result
    interview_file=$(mktemp)
    note_file="${PEOPLE_DIR}/${person_name}.md"
    trap 'rm -f "$interview_file"' RETURN
    printf '%s\n' "$5" >"$interview_file"

    [[ -f "$TEMPLATE" ]] || { echo "parse_pgpow: template not found: $TEMPLATE" >&2; return 1; }

    result=$(python3 - "$note_file" "$TEMPLATE" "$person_name" "$image" "$interview_file" "$person_link" "$mode" "$POW_TAG" <<'PY'
import re
import subprocess
import sys
from datetime import date
from pathlib import Path

note_path = Path(sys.argv[1])
template_path = Path(sys.argv[2])
name = sys.argv[3]
image = sys.argv[4]
interview_path = Path(sys.argv[5])
interview_url = sys.argv[6]
mode = sys.argv[7]
pow_tag = sys.argv[8]
people_tag = "🐘😇People"
template_strip_tags = {"DRW"}
interview_marker = "### Please tell us about yourself"
interview_text = interview_path.read_text(encoding="utf-8").strip()

parts = name.split(None, 1)
incoming_name = {
    "first_name": parts[0],
    "middle_name": "",
    "last_name": parts[1] if len(parts) > 1 else "",
}


def yaml_scalar(value):
    if value is None:
        return ""
    if isinstance(value, list):
        return ", ".join(str(x).strip() for x in value if str(x).strip())
    return str(value).strip()


def parse_frontmatter(text):
    m = re.match(r"^---\n(.*?)\n---\n?", text, re.S)
    if not m:
        return {}, [], text
    fm_text = m.group(1)
    body = text[m.end() :]
    data = {}
    order = []
    current_key = None
    for line in fm_text.splitlines():
        if not line.strip():
            continue
        if line.startswith((" ", "\t")) and current_key:
            data[current_key] = (data.get(current_key, "") + "\n" + line.rstrip()).strip("\n")
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        data[key] = value.strip()
        order.append(key)
        current_key = key
    return data, order, body


def render_frontmatter(data, order):
    seen = set()
    lines = ["---"]
    for key in order:
        if key in data and key not in seen:
            value = data.get(key, "")
            if "\n" in value:
                lines.append(f"{key}:")
                lines.extend(value.splitlines())
            else:
                lines.append(f"{key}: {value}" if yaml_scalar(value) else f"{key}: ")
            seen.add(key)
    for key, value in data.items():
        if key not in seen:
            if "\n" in value:
                lines.append(f"{key}:")
                lines.extend(value.splitlines())
            else:
                lines.append(f"{key}: {value}" if yaml_scalar(value) else f"{key}: ")
    lines.append("---")
    lines.append("")
    return "\n".join(lines)


def parse_tag_items(value):
    items = []
    if isinstance(value, list):
        raw = value
    else:
        raw = yaml_scalar(value).splitlines() if "\n" in yaml_scalar(value) else re.split(r"[,;]", yaml_scalar(value))
    for item in raw:
        item = re.sub(r"^\s*-\s*", "", yaml_scalar(item)).strip()
        if item and item not in items:
            items.append(item)
    return items


def render_tags(items, *, prefer_list=False):
    cleaned = []
    seen = set()
    for item in items:
        item = yaml_scalar(item)
        if not item or item in seen:
            continue
        cleaned.append(item)
        seen.add(item)
    if not cleaned:
        return ""
    if prefer_list or len(cleaned) > 1:
        return "\n".join(f"  - {item}" for item in cleaned)
    return cleaned[0]


def ensure_tags(existing, *required):
    items = parse_tag_items(existing)
    for tag in required:
        if tag not in items:
            items.append(tag)
    return items


def normalize_alias_key(value):
    return re.sub(r"\s+", " ", yaml_scalar(value)).strip().casefold()


def alias_known(vals, alias):
    key = normalize_alias_key(alias)
    return any(normalize_alias_key(a) == key for a in vals)


def merge_aliases(existing, *incoming):
    vals = []
    for alias in parse_tag_items(existing):
        if alias and not alias_known(vals, alias):
            vals.append(alias)
    for raw in incoming:
        if not raw:
            continue
        for alias in parse_tag_items(raw):
            if alias and not alias_known(vals, alias):
                vals.append(alias)
    prefer_list = "\n" in yaml_scalar(existing) or len(vals) > 1
    return render_tags(vals, prefer_list=prefer_list) if vals else ""


def merge_pow_frontmatter(old, order, *, is_new, canonical_name):
    merged = dict(old)
    if is_new:
        merged.pop("tags", None)
        if yaml_scalar(merged.get("company", "")) in ("DRW", "[[companies/DRW]]"):
            merged.pop("company", None)

    today = date.today().isoformat()
    for key, value in incoming_name.items():
        value = yaml_scalar(value)
        if is_new:
            merged[key] = value
        elif not yaml_scalar(merged.get(key, "")):
            merged[key] = value

    if is_new and not yaml_scalar(merged.get("date", "")):
        merged["date"] = today

    old_tags = parse_tag_items(merged.get("tags", ""))
    new_tags = ensure_tags(merged.get("tags", ""), people_tag, pow_tag)
    if new_tags != old_tags:
        merged["tags"] = render_tags(new_tags, prefer_list=True)

    old_aliases = parse_tag_items(merged.get("aliases", ""))
    merged_aliases = merge_aliases(merged.get("aliases", ""), name)
    if parse_tag_items(merged_aliases) != old_aliases:
        merged["aliases"] = merged_aliases
        if "aliases" not in order:
            order.append("aliases")

    for key in incoming_name:
        if key not in order:
            order.append(key)
    if "tags" not in order:
        order.append("tags")
    if is_new and "date" in merged and "date" not in order:
        order.append("date")
    return merged, order


def has_interview(body):
    if interview_marker in body:
        return True
    if "postgresql.life/post/" in body:
        return True
    if interview_url and interview_url.rstrip("/") in body:
        return True
    return False


def first_image_line(body):
    return re.search(r"(?m)^!\[[^\]\n]*\]\([^)\n]*\)\s*$", body)


def is_placeholder_image(line):
    m = re.match(r"^!\[([^\]]*)\]\(([^)]*)\)\s*$", line)
    if not m:
        return False
    alt, url = m.group(1).strip(), m.group(2).strip()
    if not url:
        return True
    if url.startswith("assets/"):
        return False
    if "postgresql.life" in url:
        return False
    return alt in ("", "|250")


def update_header_image(body, header_line):
    m = first_image_line(body)
    if not m:
        return header_line + "\n\n" + body.lstrip("\n")
    line = m.group(0)
    if is_placeholder_image(line):
        start, end = m.span()
        return body[:start] + header_line + body[end:]
    return body


def append_interview(body, text):
    if not text:
        return body
    dv = re.search(r"```dataview.*?```", body, re.S)
    if dv:
        insert_at = dv.end()
        chunk = body[insert_at:]
        if chunk.startswith("\r\n"):
            insert_at += 2
        elif chunk.startswith("\n"):
            insert_at += 1
        return body[:insert_at] + "\n\n" + text + "\n" + chunk.lstrip("\n")
    img = first_image_line(body)
    if img:
        insert_at = img.end()
        chunk = body[insert_at:]
        if chunk.startswith("\r\n"):
            insert_at += 2
        elif chunk.startswith("\n"):
            insert_at += 1
        return body[:insert_at] + "\n\n" + text + "\n" + chunk.lstrip("\n")
    sep = "\n\n" if body.strip() else ""
    return body.rstrip() + sep + text + "\n"


def default_body(header_line):
    return "\n".join(
        [
            header_line,
            "",
            "```dataview",
            'TABLE WITHOUT ID file.name as "full name", title, phone, work_email',
            'FROM "people"',
            "WHERE file.name = this.file.name",
            "```",
            "",
        ]
    )


def load_page():
    if note_path.exists():
        return parse_frontmatter(note_path.read_text(encoding="utf-8", errors="replace")) + (False,)
    text = template_path.read_text(encoding="utf-8", errors="replace")
    text = text.replace("{{title}}", name).replace("{{date}}", date.today().isoformat())
    return parse_frontmatter(text) + (True,)


data, order, body, is_new = load_page()
canonical = note_path.stem
header_line = f"![{name}|250]({image})"

body_before = body
tags_before = set(parse_tag_items(data.get("tags", "")))
aliases_before = parse_tag_items(data.get("aliases", ""))

merged, order = merge_pow_frontmatter(data, order, is_new=is_new, canonical_name=canonical)
body = update_header_image(body, header_line)
if interview_text and not has_interview(body):
    body = append_interview(body, interview_text)
elif is_new and not body.strip():
    body = default_body(header_line)
    if interview_text:
        body = append_interview(body, interview_text)

tags_after = set(parse_tag_items(merged.get("tags", "")))
aliases_after = parse_tag_items(merged.get("aliases", ""))
names_filled = any(
    not yaml_scalar(data.get(key, "")) and yaml_scalar(merged.get(key, ""))
    for key in incoming_name
)
changed = (
    is_new
    or body != body_before
    or tags_before != tags_after
    or aliases_before != aliases_after
    or names_filled
)
status = "created" if is_new else ("updated" if changed else "unchanged")
note = render_frontmatter(merged, order) + body.lstrip("\n")

if mode == "markdown":
    print(note, end="")
    raise SystemExit(0)

if status == "unchanged":
    print(f"STATUS:unchanged")
    raise SystemExit(0)

note_path.parent.mkdir(parents=True, exist_ok=True)
note_path.write_text(note, encoding="utf-8")
if is_new:
    helper = Path.home() / "bin" / "obsidian_ensure_filename_alias"
    if helper.is_file():
        subprocess.run([str(helper), str(note_path)], check=False)
print(f"STATUS:{status}")
PY
)

    case "$result" in
        STATUS:created)
            log "created ${person_name} (${person_link})"
            [[ "${quiet:-0}" -eq 0 ]] && echo "parse_pgpow: created ${note_file}" >&2
            echo "STATUS:created"
            return 0
            ;;
        STATUS:updated)
            log "updated ${person_name} (${person_link})"
            [[ "${quiet:-0}" -eq 0 ]] && echo "parse_pgpow: updated ${note_file}" >&2
            echo "STATUS:updated"
            return 0
            ;;
        STATUS:unchanged)
            log "unchanged ${person_name}"
            [[ "${quiet:-0}" -eq 0 ]] && echo "parse_pgpow: unchanged ${note_file}" >&2
            echo "STATUS:unchanged"
            return 2
            ;;
        *)
            echo "parse_pgpow: apply failed for ${person_name}" >&2
            echo "STATUS:failed"
            return 1
            ;;
    esac
}

process_person() {
    local person_link="$1"
    local parsed person_name status_line rc=0

    parsed=$(fetch_markdown "$person_link")
    parse_fetched "$parsed"
    [[ -n "$PARSED_TITLE" ]] || { log "skip unreadable interview: ${person_link}"; return 3; }

    person_name="$PARSED_TITLE"
    status_line=$(apply_pow_note write "$person_name" "$person_link" "$PARSED_IMAGE" "$PARSED_BODY") || rc=$?
    case "$status_line" in
        STATUS:created|STATUS:updated) ;;
        STATUS:unchanged) return 2 ;;
        *) return 1 ;;
    esac

    if [[ "${open_obsidian:-0}" -eq 1 ]]; then
        obsidian_cli -of "people/${person_name}"
    fi
    return 0
}

run_backfill() {
    local link created=0 updated=0 unchanged=0 failed=0

    while IFS= read -r link; do
        [[ -z "$link" ]] && continue
        set +e
        parsed=$(fetch_markdown "$link")
        parse_fetched "$parsed"
        if [[ -z "$PARSED_TITLE" ]]; then
            log "backfill skip unreadable: ${link}"
            ((failed++)) || true
            set -e
            continue
        fi

        status_line=$(apply_pow_note write "$PARSED_TITLE" "$link" "$PARSED_IMAGE" "$PARSED_BODY" 2>/dev/null) || true
        case "$status_line" in
            STATUS:created) ((created++)) || true ;;
            STATUS:updated) ((updated++)) || true ;;
            STATUS:unchanged) ((unchanged++)) || true ;;
            *) ((failed++)) || true ;;
        esac
        set -e
    done < <(list_interviews)

    echo "parse_pgpow backfill: created ${created}, updated ${updated}, unchanged ${unchanged}, failed ${failed}"
    log "backfill complete: created=${created} updated=${updated} unchanged=${unchanged} failed=${failed}"
}

mode="create"
query=""
open_obsidian=1
quiet=0
backfill=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --latest) query="--latest" ;;
        --backfill) backfill=1 ;;
        --markdown) mode="markdown" ;;
        --open) open_obsidian=1 ;;
        --quiet) quiet=1; open_obsidian=0 ;;
        -h|--help) usage; exit 0 ;;
        -*) echo "parse_pgpow: unknown option $1" >&2; usage >&2; exit 1 ;;
        *) query="$1" ;;
    esac
    shift
done

if [[ "$backfill" -eq 1 ]]; then
    quiet=1
    open_obsidian=0
    run_backfill
    exit 0
fi

if [[ -z "$query" ]]; then
    if command -v xclip >/dev/null 2>&1; then
        query=$(xclip -o 2>/dev/null | head -1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    fi
    [[ -z "$query" ]] && { echo "parse_pgpow: provide a name or use --latest" >&2; usage >&2; exit 1; }
fi

[[ "$query" == "--latest" ]] && quiet=1 && open_obsidian=0

IFS=$'\t' read -r person_name slug person_link < <(resolve_person "$query")

parsed=$(fetch_markdown "$person_link")
parse_fetched "$parsed"
[[ -n "$PARSED_TITLE" ]] && person_name="$PARSED_TITLE"

if [[ "$mode" == "markdown" ]]; then
    apply_pow_note markdown "$person_name" "$person_link" "$PARSED_IMAGE" "$PARSED_BODY"
    exit 0
fi

if [[ "$query" == "--latest" && -f "${PEOPLE_DIR}/${person_name}.md" ]]; then
    log "skip existing ${person_name}"
    exit 0
fi

status_line=$(apply_pow_note write "$person_name" "$person_link" "$PARSED_IMAGE" "$PARSED_BODY") || true
case "$status_line" in
    STATUS:created|STATUS:updated|STATUS:unchanged) ;;
    *)
        echo "parse_pgpow: failed to apply note for ${person_name}" >&2
        exit 1
        ;;
esac

if [[ "$open_obsidian" -eq 1 ]]; then
    obsidian_cli -of "people/${person_name}"
fi