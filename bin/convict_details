#!/bin/bash
#===============================================================================
#
#          FILE:  convict_details
# 
#         USAGE:  ./convict_details 
# 
#   DESCRIPTION:  Get the details about a convict and make an obsidian object
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  06/29/2024 06:00:06 PM CDT
#      REVISION:  ---
#===============================================================================


ScriptVersion="1.0"
first_name=
last_name=
tdcj=
logging=0

function die() {
    code=$1
    shift
    echo -e "$@" >2
    exit $code
}

function tdcj_getsid(){

    wget -q -O - --post-data "page=index&$@" https://inmate.tdcj.texas.gov/InmateSearch/search.action |  grep viewDetail | sed -e 's/^.*href="//' -e 's/".*$//'

}

function tdcj_pull_line() {
    grep -A2 "$@" | tail -n 1 | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//'
}

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options: 

  -d|debug       Cumulative logging (e.g  -ddd)
  -f|first name  Name to search for, requires last name
  -h|help        Display this message
  -l|last name   Name to search for, requires first name
  -t|tdcj number Search by convict ID

  -v|version    Display script version

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":df:hl:t:v" opt
do
  case $opt in

    d|debug    ) (( logging++ ));;

    f|first    ) first_name="${OPTARG^^}";;

    h|help     )  usage; exit 0   ;;

    l|last     ) last_name="${OPTARG^^}";;

    t|tdcj     ) tdcj="$OPTARG";;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

[[ $logging -gt 2 ]] && set -x

[[ "$tdcj" == '' ]] && [[ "$first_name" == '' ]] && [[ "$last_name" == '' ]] && { 
    usage
    die 1 "Input required"
    }

[[ ! "$tdcj" == '' ]] && {
   
    [[ $logging -gt 0 ]] && echo "Using TDCJ Lookup"

    sids=$(tdcj_getsid tdcj=$tdcj)
    IFS=$'\n'
    for sid in ${sids[@]}
    do
        
        [[ $logging -gt 0 ]] && echo "Processing SID: $sid"

        sidnumber=$(echo "$sid" | sed -e 's/^.*=//')
        wget -q -t 5 -O - https://inmate.tdcj.texas.gov$sid > $sidnumber
        tdcjnumber=$(cat $sidnumber | tdcj_pull_line 'TDCJ Number')
        inmatename=$(cat $sidnumber | tdcj_pull_line 'Name:')
        inmaterace=$(cat $sidnumber | tdcj_pull_line 'Race:')
        inmategender=$(cat $sidnumber | tdcj_pull_line 'Gender:')
        inmateage=$(cat $sidnumber | tdcj_pull_line 'Age:')
        maxsentence=$(cat $sidnumber | tdcj_pull_line 'Maximum Sentence Date')
        facility=$(cat $sidnumber | tdcj_pull_line 'Current Facility')
        projectedrelease=$(cat $sidnumber | tdcj_pull_line 'Projected Release')
        paroleeligibility=$(cat $sidnumber | tdcj_pull_line 'Parole Eligibility Date')
        visitation=$(cat $sidnumber | tdcj_pull_line 'Visitation Eligible')
        
        history_start=$(cat $sidnumber | grep -n 'Offense History' | sed 's/:.*$//')
        history_end=$(cat $sidnumber | grep -n '</table>' | sed 's/:.*$//')
        offensehistory=$(cat $sidnumber | 
            sed -n "${history_start},${history_end}p" | 
            dos2unix | 
            sed -e '/<h3>/d' -e 's/\t//g' -e 's/^[[:space:]]*//' | 
            sed -e '/^[[:space:]]*$/d' -e 's_</c:out>__g' |
            sed -e '/div class="overflow"/d'
        )

        rm $sidnumber
        inmatefile=~/Documents/notes/people/$inmatename.md
        # [[ -f $inmatefile ]] && die 5 "File already exists."
        imln=$(echo "$inmatename" | cut -d, -f1)
        inmatename=$(echo "$inmatename" | sed "s/^$imln,//")
        imfn=$(echo "$inmatename" | cut -d' ' -f1)
        inmatename=$(echo "$inmatename" | sed -e "s/^$imfn//" -e 's/[[:space:]]*//g')
        immn="$inmatename"
        echo "---
first_name: $imfn
middle_name: $immn
last_name: $imln
tags:
 - convict
date: $(date +'%F')
sid: $sidnumber
tdcj: $tdcjnumber
---

\`\`\`dataview
TABLE WITHOUT ID file.name as \"full name\", sid, tdcj, tags
FROM \"people\"
WHERE file.name = this.file.name
\`\`\`

# Inmate Information Details

| name | value |
|------|-------|
| SID  | $sidnumber |
| TDCJ | $tdcjnumber |
| Name | $imln,$imfn $immn |
| Race | $inmaterace |
| Gender | $inmategender |
| Age | $inmateage |
| Max Sentence | $maxsentence |
| Current Facility | $facility |
| Projected Release | $projectedrelease |
| Parole Eligibility | $paroleeligibility |
| Visitation | $visitation |

## Offence History

$offensehistory

" > "$inmatefile"

    done
    exit
}

[[ "$first_name" == '' ]] || [[ "$last_name" == '' ]] && {
    usage
    die 2 "Both first and last name are required."

    exit
}

# fn,ln
sid=$(tdcj_getsid firstName=$first_name&lastName=$last_name)



echo "How the hell did we get here?"

