#!/bin/bash
#===============================================================================
#
#          FILE:  convict_format_top
# 
#         USAGE:  ./convict_format_top 
# 
#   DESCRIPTION:  Take a blob of text from a TDCJ report and format it as a table
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  06/29/2024 05:28:45 PM CDT
#      REVISION:  ---
#===============================================================================

buffer="| name | value |
|--------|-------|
"
buffer="$buffer $(xclip -o | sed -e '/^[[:space:]]*$/d' | 
    sed -e 's/^/|/' -e 's/$/|/' -e 's/:/|/')"

echo -e "$buffer" | xclip -selection clipboard
