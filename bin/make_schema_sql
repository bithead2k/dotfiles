set -o nounset                              # Treat unset variables as an error

[[ -z $1 ]] && {
    echo "requires schema ticket number as parameter"
    exit 1
}

pbpaste | ssh sync01bd.d.tripadvisor.com "cat - > ~/source/schema/SCHEMA-$1.sql"
