#!/opt/local/bin/bash
#===============================================================================
#
#          FILE: merge_ahc
# 
#         USAGE: ./merge_ahc 
# 
#   DESCRIPTION: Merge the second AHC into the first AHC.
# 
#       OPTIONS: --target --source
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (), kirk.roybal@2ndquadrant.com
#  ORGANIZATION: 
#       CREATED: 09/20/2018 08:37
#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error
set -u


#---  FUNCTION  ----------------------------------------------------------------
#          NAME:  die
#   DESCRIPTION:  print a message and terminate
#    PARAMETERS:  code message 
#       RETURNS:  nothing
#-------------------------------------------------------------------------------
function die() {
    echo "$1"
    exit $2
}


ScriptVersion="1.0"

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options:
  -d|debug           Set bash debugging mode
  -s|source file     File formatted as an AHC from 2Q 
  -t|target file     File formatted as an AHC from 2Q
  -h|help            Display this message
  -v|version         Display script version

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":dhs:t:v" opt
do
  case $opt in

    d|debug    ) set -x;;

    h|help     )  usage; exit 0   ;;

    s|source   )  source=$OPTARG;;

    t|target   )  target=$OPTARG;;


    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))

[[ -z "${source:-}" ]] && die "Source file not given" 1
[[ -z "${target:-}" ]] && die "Target file not given" 1

[[ ! -f "${source}" ]] && die "Source file not found" 2
[[ ! -f "${target}" ]] && die "Target file not found" 2

IFS=$'\n'
source_sections=($(grep "^#" "${source}"))

target_sections=($(grep "^#" "${target}"))

for index in "${!source_sections[@]}"
do
    # peek the next item
    (( j=index+1 ))
    
    # find the section end by the next header, if there is no end, then eof
    dest="$"
    [[ -z "${source_sections[${j}]:-}" ]] || dest=$(grep -n "^${source_sections[${j}]}$" "$source" | sed "s/:.*//")
    
    # get the section, strip the headers on each end
        #...creates bogus line continuations for sed
    section=$(sed -ne "/^${source_sections[${index}]}$/,${dest}p" "$source" | sed -e '$d' -e '1d' | sed 's_$_\\_' ) 

    # find the destination header in the target file
    dest="$"
    [[ -z "${source_sections[${j}]:-}" ]] || dest=$(grep -n "^${target_sections[${j}]}$" "$target" | sed "s/:.*//")

    # prepend the section just above the next header
    sed -i "${dest}i \\
$section"  "$target"

    # get rid of the bogus line continuation characters
    sed -i 's/\\$//' "${target}"

done
