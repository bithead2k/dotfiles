#!/opt/local/bin/bash
#===============================================================================
#
#          FILE: pushpix
# 
#         USAGE: ./pushpix 
# 
#   DESCRIPTION: 
# 
#       OPTIONS: ---
#  REQUIREMENTS: ---
#          BUGS: ---
#         NOTES: ---
#        AUTHOR: Kirk Roybal (), kirk@webfinish.com
#  ORGANIZATION: 
#       CREATED: 04/15/2015 17:10
#      REVISION:  ---
#===============================================================================

set -o nounset                              # Treat unset variables as an error



ScriptVersion="1.0"

#===  FUNCTION  ================================================================
#         NAME:  usage
#  DESCRIPTION:  Display usage information.
#===============================================================================
function usage ()
{
	cat <<- EOT

  Usage :  ${0##/*/} [options] [--] 

  Options: 
  -d|dir  name  Directory to push
  -h|help       Display this message
  -v|version    Display script version

	EOT
}    # ----------  end of function usage  ----------

#-----------------------------------------------------------------------
#  Handle command line arguments
#-----------------------------------------------------------------------

while getopts ":d:hv" opt
do
  case $opt in

    d|dir      )  directory=$OPTARG;;

    h|help     )  usage; exit 0   ;;

    v|version  )  echo "$0 -- Version $ScriptVersion"; exit 0   ;;

    \? )  echo -e "\n  Option does not exist : $OPTARG\n"
          usage; exit 1   ;;

  esac    # --- end of case ---
done
shift $(($OPTIND-1))


ssh -t webf@webfinish.com "mkdir -p ~/public_html/pix/$directory"
scp $directory/* webf@webfinish.com:~/public_html/pix/$directory/
