set -o nounset                              # Treat unset variables as an error

function instr() {

  [[ $(grep "$2" "$1" | wc -l) -gt 0 ]] && echo 1

}

duedate=$(/bin/date -v+4d +'%m/%d/%Y')
sed -i -e 's/supportability check/architectural health check/g' \
	-e 's/author: 2ndQuadrant/author:\n - 2ndQuadrant\n - Kirk Roybal/' \
	-e '/title: Database/s/.*/title: Architectural Health Check/' \
	-e "/Revision 1.0/s_< date >; < name of author/engineer >_$duedate;Kirk L. Roybal_" \
        -e "/customer:/s/.*/customer: $2/" $1

[[ $(grep 'classification: partner-confidential' $1 | wc -l) -eq 0 ]] && sed -i -e '2iclassification: partner-confidential' $1


[[ $(instr $1 '|YELLOW|Read-ahead settings') ]] && {

DEVICES=$(grep 'YELLOW|Read-ahead settings must be checked' $1 | sed -e 's/^.*: //' -e 's/ loaded=.*$//')

DEVICES=$(echo ${DEVICES} | sed -e 's/ /\n    /g')

SETTINGS=$(echo "${DEVICES[@]}" | sed -e 's_^_ # /sbin/blockdev --setra 4096 _' -e 's/=.*$//' -e 's/^[[:space:]]*/    /')

DATA="### Read-Ahead

Having a sufficiently sized read-ahead buffer can significantly increase a
storage devices' sequential read performance without adversely affecting other
access patterns.  These are the Linux default settings for read-ahead:

    ${DEVICES[@]}

The readahead on the database storage drives is set to [:TODO:].  The default
read-ahead value on the database device does not offer the best performance.
The optimal value depends on the storage system, with larger disk arrays
benefiting from higher values, particularly for large sequential scans.

As the database is using a fairly large disk array, we recommend increasing the
value to 8192 or perhaps even 16384. With the current amount of I/O operations,
a positive impact can be expected here. It is possible, though, that the storage
already uses a read-ahead on its own.

Here is an example of checking and setting readahead values:

${SETTINGS[@]}
"

# Add "\n" to the end of lines, then strip off the newline
DATA=$(echo -e "$DATA" | sed -e 's_$_\\n_g' | tr -d '\n')

# Use sed to replace with multiline text, restoring the newline
sed -i -e "/|YELLOW|Read-ahead settings/s|.*|${DATA}|" $1

# Add this item to the follow-up section
sed -i -e '/Follow-up recommendations/a\
\* Size the read-ahead buffer' $1

}

[[ $(instr $1 '|YELLOW|Transparent Huge Pages are enabled') ]] && {

DATA="### Transparent Huge Pages

Transparent Huge Pages (THP) should be disabled.  In our experience it can
cause significant performance degradations as memory becomes more fragmented.
As PostgreSQL can not really benefit from transparent huge pages, and the issues
caused by defragmentation are very common, we strongly recommend disabling THP.
Simply set all the options to **never** or **no**.

    echo never > /sys/kernel/mm/transparent_hugepage/enabled
    echo never > /sys/kernel/mm/transparent_hugepage/defrag
    echo no > /sys/kernel/mm/transparent_hugepage/khugepaged/defrag

Recent PostgreSQL versions (since 9.4) can however benefit from using explicit
Huge Pages for shared memory (**shared_buffers** etc.). This requires determining
the necessary number of huge pages using **VmPeak**, hugepage size (typically 2MB)
and then settings **vm.nr_hugepages** kernel parameter.

The procedure is discussed in the [online documentation](https://www.postgresql.org/docs/current/static/kernel-resources.html#LINUX-HUGE-PAGES)
but a short version is:

    $ head -1 /path/to/data/directory/postmaster.pid
    4170
    $ grep ^VmPeak /proc/4170/status
    VmPeak:  6490428 kB

    $ cat /proc/meminfo \| grep Hugepagesize
    Hugepagesize:       2048 kB

    $ sysctl -w vm.nr_hugepages=3170

This will give you the benefits of huge pages (lower overhead) when managing
the large shared memory area, but without the issues associated with
defragmenting memory for regular allocations.


To prevent the changed values from being enabled by default by a server reboot,
the bootloader needs to be modified.  For example, this can be achieved with
grub by running:

    grubby --update-kernel=ALL --args='transparent_hugepage=never'
"

# Add "\n" to the end of lines, then strip off the newline
DATA=$(echo -e "$DATA" | sed -e 's_$_\\n_g' | tr -d '\n')

# Use sed to replace with multiline text, restoring the newline
sed -i -e "/|YELLOW|Transparent Huge Pages/s|.*|${DATA}|" $1

# Add this item to the follow-up section
sed -i -e '/Follow-up recommendations/a\
\* Turn off transparent huge pages' $1

}

[[ $(instr $1 'YELLOW|log_checkpoints is off') ]] && {

DATA='
### log_checkpoints is off

Logging checkpoints also logs restartpoints, and is generally recommended.   Some statistics are included in the log messages, including the number of buffers written and the time spent writing them.  This information is valuable to determine how often checkpoints are reached, and further tune the checkpoints parameters.

'

# Add "\n" to the end of lines, then strip off the newline
DATA=$(echo -e "$DATA" | sed -e 's_$_\\n_g' | tr -d '\n')

