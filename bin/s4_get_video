#!/bin/bash

# Quick script to get the video off of the S4 Galaxy camera that is mounted to
# the portable tripod. 
# Takes no parameters, no overrides.
# TODO:  put in command line parameters to override all the defauls here

function die(){
  retval=$1
  shift
  echo -e "$@"
  exit $retval
}

export dcim_path=/storage/extSdCard/DCIM/Camera
export today=$(date +'%F')
export studio_path=~/Pictures/portable_studio/${today}
export presence_check=$(adb shell exit 2>&1)
export video_list=$(adb shell ls $dcim_path/*.mp4 2>&1 | sed -e 's/[^[:print:]]*//g')

[[ $presence_check == '' ]] || die 3 "No adb device found"

[[ $video_list == "${dcim_path}/*.mp4: No such file or directory" ]] && die 1 'Nothing to transfer'

mkdir -p $studio_path && cd $studio_path || die 2 "Could not make directory $studio_path"
for video in ${video_list[@]} 
do
    #echo $video
    adb pull $video .
    adb shell rm $video
done

echo "Videos are now located in ${studio_path} and deleted from camera."
