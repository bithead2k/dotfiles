#!/bin/bash
#===============================================================================
#
#          FILE:  reset_obs
# 
#         USAGE:  ./reset_obs 
# 
#   DESCRIPTION:  unload/reload v4l2loopback to re-enable webcam for OBS
# 
#       OPTIONS:  ---
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  ---
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  07/28/2022 07:55:50 AM CDT
#      REVISION:  ---
#===============================================================================

ssh root@localhost 'rmmod v4l2loopback'
ssh root@localhost 'modprobe v4l2loopback'
