#!/bin/bash
#===============================================================================
#
#          FILE:  planner_project_list_print
# 
#         USAGE:  ./planner_project_list_print 
# 
#   DESCRIPTION:  Print the project_list.txt file
# 
#       OPTIONS:  none
#  REQUIREMENTS:  ---
#          BUGS:  ---
#         NOTES:  Adds printer formatting to project list
#        AUTHOR:  Kirk L. Roybal (), Kirk@timescale.com
#       COMPANY:  Timescale
#       VERSION:  1.0
#       CREATED:  01/10/2023 01:18:44 PM CST
#      REVISION:  ---
#===============================================================================

project_file="/home/kroybal/Documents/project_list.txt"
project_md=${project_file//.txt/.md}
project_pdf=${project_file//.txt/.pdf}

echo -e "# Project List\n" > "${project_md}"
for ((i=1;i<=$(cat "${project_file}" | wc -l);i++))
do
    line=$(sed -n "${i}p" "${project_file}")
    printf " - [ ] ———————————— · %02i: $line\n" $i
done >> "${project_md}"

# Make a pdf out of it
pandoc -s --pdf-engine=xelatex -o "${project_pdf}" "$project_md"
# Get rid of the working file
rm "${project_md}"
# Print the list to Samsung CW3060
lpr "${project_pdf}"
# Get rid of the pdf
rm "${project_pdf}"
